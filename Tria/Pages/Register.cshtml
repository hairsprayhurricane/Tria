@page
@model Tria.Pages.RegisterModel
@using Tria.Services
@inject IUiLocalizer T
@{
    ViewData["Title"] = T["Register_Title"];
    Layout = null;
    var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}

<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] – Tria</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background-color: #f3f4f6; color: #111827; }
        .page { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 24px; }
        .window { width: 100%; max-width: 420px; background-color: #fff; border: 1px solid #d1d5db; border-radius: 8px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); }
        .window-header { display: flex; align-items: center; justify-content: space-between; padding: 8px 10px; border-bottom: 1px solid #e5e7eb; background-color: #f9fafb; }
        .window-title { font-size: 12px; color: #6b7280; }
        .window-body { padding: 20px; }
        h1 { font-size: 20px; margin-bottom: 4px; }
        .subtitle { font-size: 13px; color: #6b7280; margin-bottom: 18px; }
        .field { margin-bottom: 14px; }
        .field-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: #6b7280; margin-bottom: 4px; display: block; }
        .field-input { width: 100%; padding: 8px; border-radius: 4px; border: 1px solid #d1d5db; font-size: 14px; outline: none; }
        .field-input:focus { border-color: #4b5563; }
        .validation-summary, .field-error { font-size: 12px; color: #b91c1c; margin-bottom: 8px; }
        .field-error { margin-top: 3px; }
        .btn-primary { width: 100%; padding: 8px; border-radius: 4px; border: none; background: #111827; color: white; cursor: pointer; font-size: 14px; }
        .btn-primary:hover { background: #374151; }
        .link-block { margin-top: 12px; text-align: center; font-size: 13px; }
        .link-block a { color: #111827; text-decoration: none; }
        .link-block a:hover { text-decoration: underline; }

        .lang-switcher { position: relative; display: inline-block; }
        .lang-btn { display: flex; align-items: center; gap: 4px; padding: 3px 8px; font-size: 13px; border: 1px solid #d1d5db; border-radius: 4px; background: #fff; cursor: pointer; color: #374151; }
        .lang-btn .arrow { font-size: 9px; color: #9ca3af; }
        .lang-dropdown { display: none; position: absolute; right: 0; top: calc(100% + 4px); background: #fff; border: 1px solid #d1d5db; border-radius: 6px; box-shadow: 0 6px 16px rgba(0,0,0,0.10); min-width: 150px; z-index: 100; overflow: hidden; }
        .lang-dropdown.open { display: block; }
        .lang-option { display: block; text-decoration: none; width: 100%; padding: 7px 12px; font-size: 13px; text-align: left; background: none; border: none; cursor: pointer; color: #111827; }
        .lang-option:hover { background: #f3f4f6; }
        .lang-option.active { background: #eff6ff; color: #1d4ed8; font-weight: 500; }
    </style>
</head>
<script>
function toggleLang(e) {
    e.stopPropagation();
    document.querySelector('.lang-dropdown').classList.toggle('open');
}
document.addEventListener('click', function() {
    document.querySelector('.lang-dropdown').classList.remove('open');
});
</script>
<body>
<div class="page">
    <div class="window">
        <div class="window-header">
            <div class="window-title">@T["Register_Title"]</div>
            <div class="lang-switcher">
                <button type="button" class="lang-btn" onclick="toggleLang(event)">
                    @(lang == "ru" ? "🇷🇺" : "🇬🇧") <span class="arrow">▼</span>
                </button>
                <div class="lang-dropdown">
                    <a href="/set-language?culture=en&returnUrl=/Register" class="lang-option @(lang == "en" ? "active" : "")">🇬🇧 English</a>
                    <a href="/set-language?culture=ru&returnUrl=/Register" class="lang-option @(lang == "ru" ? "active" : "")">🇷🇺 Русский</a>
                </div>
            </div>
        </div>
        <div class="window-body">
            <h1>@T["Register_Heading"]</h1>
            <p class="subtitle">@T["Register_Subtitle"]</p>

            <form method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="validation-summary"></div>
                <div class="field">
                    <label asp-for="Input.Email" class="field-label">@T["Register_Email"]</label>
                    <input asp-for="Input.Email" class="field-input" />
                    <span asp-validation-for="Input.Email" class="field-error"></span>
                </div>
                <div class="field">
                    <label asp-for="Input.Password" class="field-label">@T["Register_Password"]</label>
                    <input asp-for="Input.Password" type="password" class="field-input" />
                    <span asp-validation-for="Input.Password" class="field-error"></span>
                </div>
                <div class="field">
                    <label asp-for="Input.ConfirmPassword" class="field-label">@T["Register_ConfirmPassword"]</label>
                    <input asp-for="Input.ConfirmPassword" type="password" class="field-input" />
                    <span asp-validation-for="Input.ConfirmPassword" class="field-error"></span>
                </div>
                <button type="submit" class="btn-primary">@T["Register_Submit"]</button>
            </form>

            <div class="link-block">
                @T["Register_HaveAccount"] <a asp-page="./Login">@T["Register_Login"]</a>
            </div>
        </div>
    </div>
</div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
