@page
@model Tria.Pages.RegisterModel
@{
    ViewData["Title"] = "Регистрация";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>Регистрация – Tria</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background-color: #f3f4f6;
            color: #111827;
        }
        .page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }
        .window {
            width: 100%;
            max-width: 420px;
            background-color: #ffffff;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        }
        .window-body { padding: 20px; }
        h1 { font-size: 20px; margin-bottom: 4px; }
        .subtitle { font-size: 13px; color: #6b7280; margin-bottom: 18px; }
        .field { margin-bottom: 14px; }
        .field-label { font-size: 12px; margin-bottom: 4px; display:block; }
        .field-input {
            width: 100%;
            padding: 8px;
            border-radius: 4px;
            border: 1px solid #d1d5db;
        }
        .validation-summary, .field-error {
            font-size: 12px;
            color: #b91c1c;
            margin-bottom: 8px;
        }
        .btn-primary {
            width: 100%;
            padding: 8px;
            border-radius: 4px;
            border: none;
            background: #111827;
            color: white;
            cursor: pointer;
        }
        .btn-primary:hover { background: #374151; }
    </style>
</head>
<body>
<div class="page">
    <div class="window">
        <div class="window-body">

            <h1>Создание аккаунта</h1>
            <p class="subtitle">Учётная запись для обучения кибербезопасности.</p>

            <form method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="validation-summary"></div>

                <div class="field">
                    <label asp-for="Input.Email" class="field-label"></label>
                    <input asp-for="Input.Email" class="field-input" />
                    <span asp-validation-for="Input.Email" class="field-error"></span>
                </div>

                <div class="field">
                    <label asp-for="Input.Password" class="field-label"></label>
                    <input asp-for="Input.Password" type="password" class="field-input" />
                    <span asp-validation-for="Input.Password" class="field-error"></span>
                </div>

                <div class="field">
                    <label asp-for="Input.ConfirmPassword" class="field-label"></label>
                    <input asp-for="Input.ConfirmPassword" type="password" class="field-input" />
                    <span asp-validation-for="Input.ConfirmPassword" class="field-error"></span>
                </div>

                <button type="submit" class="btn-primary">
                    Зарегистрироваться
                </button>
            </form>

        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>