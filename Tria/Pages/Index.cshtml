@page
@model IndexModel
@using Tria.Services
@inject IUiLocalizer T
@{
    ViewData["Title"] = T["Index_Title"];
    Layout = null;
    var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}

<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] – Tria</title>
    <script>
        // Применяем тему до рендера — без мигания
        (function() {
            if (localStorage.getItem('theme') === 'dark')
                document.documentElement.setAttribute('data-theme', 'dark');
        })();
    </script>
    <style>
        :root {
            --bg:           #f3f4f6;
            --surface:      #ffffff;
            --surface-2:    #f9fafb;
            --border:       #d1d5db;
            --border-2:     #e5e7eb;
            --text:         #111827;
            --text-muted:   #6b7280;
            --text-sub:     #4b5563;
            --text-light:   #374151;
            --progress-bg:  #e5e7eb;
            --shadow-sm:    rgba(0,0,0,0.05);
            --shadow-md:    rgba(0,0,0,0.08);
        }
        [data-theme="dark"] {
            --bg:           #0f1117;
            --surface:      #1a1d2e;
            --surface-2:    #151826;
            --border:       #2a2d3e;
            --border-2:     #222536;
            --text:         #f1f5f9;
            --text-muted:   #94a3b8;
            --text-sub:     #cbd5e1;
            --text-light:   #e2e8f0;
            --progress-bg:  #2a2d3e;
            --shadow-sm:    rgba(0,0,0,0.3);
            --shadow-md:    rgba(0,0,0,0.4);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background-color: var(--bg);
            color: var(--text);
            transition: background-color 0.3s ease, color 0.3s ease;
        }
        .page { min-height: 100vh; padding: 24px; }
        .shell { max-width: 1200px; margin: 0 auto; }

        .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; gap: 12px; }
        .top-title { font-size: 20px; font-weight: 600; color: var(--text); }
        .top-subtitle { font-size: 12px; color: var(--text-muted); }

        /* Controls row — lang + theme */
        .controls { display: flex; align-items: center; gap: 8px; }

        /* Theme button */
        .theme-btn {
            width: 34px; height: 34px;
            border: 1px solid var(--border);
            border-radius: 6px;
            background: var(--surface);
            cursor: pointer;
            font-size: 16px;
            display: flex; align-items: center; justify-content: center;
            transition: border-color 0.2s, transform 0.3s ease, background-color 0.3s;
        }
        .theme-btn:hover { border-color: var(--text-muted); }

        /* Lang switcher */
        .lang-switcher { position: relative; display: inline-block; }
        .lang-btn {
            display: flex; align-items: center; gap: 6px;
            padding: 6px 10px; font-size: 14px;
            border: 1px solid var(--border); border-radius: 6px;
            background: var(--surface); cursor: pointer;
            color: var(--text-light); white-space: nowrap;
            transition: border-color 0.2s, background-color 0.3s;
        }
        .lang-btn:hover { border-color: var(--text-muted); }
        .lang-btn .arrow { font-size: 10px; color: var(--text-muted); }
        .lang-dropdown {
            display: none;
            position: absolute; right: 0; top: calc(100% + 4px);
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 6px; box-shadow: 0 8px 20px var(--shadow-md);
            min-width: 160px; z-index: 100; overflow: hidden;
            transition: background-color 0.3s;
        }
        .lang-dropdown.open { display: block; }
        .lang-option {
            display: block; text-decoration: none; width: 100%;
            padding: 8px 14px; font-size: 14px; text-align: left;
            background: none; border: none; cursor: pointer;
            color: var(--text); white-space: nowrap;
            transition: background-color 0.15s;
        }
        .lang-option:hover { background: var(--border-2); }
        .lang-option.active { background: var(--border-2); color: #2563eb; font-weight: 500; }

        .summary-box {
            background-color: var(--surface); border: 1px solid var(--border);
            border-radius: 8px; padding: 16px 18px; margin-bottom: 18px;
            display: flex; justify-content: space-between; align-items: center;
            transition: background-color 0.3s, border-color 0.3s;
        }
        .summary-text { font-size: 14px; color: var(--text-sub); }
        .summary-badge { padding: 6px 10px; border-radius: 999px; font-size: 12px; font-weight: 600; }
        .summary-badge-ok { background-color: #dcfce7; color: #15803d; border: 1px solid #15803d; }
        .summary-badge-progress { background-color: var(--progress-bg); color: var(--text-light); border: 1px solid var(--border); }

        .blocks-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 18px; }
        .block-link { text-decoration: none; color: inherit; }
        .block-card {
            background-color: var(--surface); border-radius: 8px;
            border: 1px solid var(--border); box-shadow: 0 8px 20px var(--shadow-sm);
            transition: transform 0.18s, box-shadow 0.18s, background-color 0.3s, border-color 0.3s;
            cursor: pointer;
        }
        .block-card:hover { transform: translateY(-3px); box-shadow: 0 12px 24px var(--shadow-md); }
        .block-header { padding: 14px 16px; border-bottom: 1px solid var(--border-2); background-color: var(--surface-2); transition: background-color 0.3s, border-color 0.3s; }
        .block-title { font-size: 15px; font-weight: 600; color: var(--text); margin-bottom: 4px; }
        .block-badge { font-size: 11px; color: var(--text-muted); }
        .block-body { padding: 14px 16px 16px; }
        .block-desc { font-size: 13px; color: var(--text-sub); margin-bottom: 10px; }
        .progress-bar-bg { width: 100%; height: 8px; border-radius: 999px; background-color: var(--progress-bg); overflow: hidden; margin-bottom: 6px; transition: background-color 0.3s; }
        .progress-bar-fill { height: 100%; border-radius: 999px; background-color: #2563eb; transition: width 0.4s; }
        .block-progress-text { font-size: 12px; color: var(--text-light); text-align: right; }

        .bottom-bar { margin-top: 24px; display: flex; justify-content: flex-end; }
        .btn-logout { padding: 8px 18px; font-size: 13px; border-radius: 4px; border: 1px solid #b91c1c; background-color: #b91c1c; color: #f9fafb; cursor: pointer; }
        .btn-logout:hover { background-color: #991b1b; }
    </style>
</head>
<body>
    <div class="page">
        <div class="shell">

            <header class="top-bar">
                <div>
                    <div class="top-title">@T["Index_Heading"]</div>
                    <div class="top-subtitle">@T["Index_SubHeading"]</div>
                </div>
                <div class="controls">
                    <!-- Theme toggle -->
                    <button type="button" class="theme-btn" id="theme-btn" onclick="toggleTheme()">🌙</button>

                    <!-- Lang switcher -->
                    <div class="lang-switcher">
                        <button type="button" class="lang-btn" id="lang-btn" onclick="toggleLang(event)">
                            @(lang == "ru" ? "🇷🇺 Русский" : "🇬🇧 English")
                            <span class="arrow">▼</span>
                        </button>
                        <div class="lang-dropdown" id="lang-dropdown">
                            <a href="/set-language?culture=en&returnUrl=/" class="lang-option @(lang == "en" ? "active" : "")">🇬🇧 English</a>
                            <a href="/set-language?culture=ru&returnUrl=/" class="lang-option @(lang == "ru" ? "active" : "")">🇷🇺 Русский</a>
                        </div>
                    </div>
                </div>
            </header>

            <section class="summary-box">
                <div class="summary-text">@T["Index_OverallProgress"] <b>@Model.OverallProgress%</b></div>
                @if (Model.OverallProgress >= 80)
                {
                    <div class="summary-badge summary-badge-ok">@T["Index_CertAchieved"]</div>
                }
                else
                {
                    <div class="summary-badge summary-badge-progress">@T["Index_InProgress"]</div>
                }
            </section>

            <section class="blocks-grid">
                @foreach (var block in Model.Blocks)
                {
                    <a href="/Blocks/@block.Id" class="block-link">
                        <article class="block-card">
                            <div class="block-header">
                                <div class="block-title">@block.Title</div>
                                <div class="block-badge">@block.Description</div>
                            </div>
                            <div class="block-body">
                                <p class="block-desc">@T["Index_BlockDesc"]</p>
                                <div class="progress-bar-bg">
                                    <div class="progress-bar-fill" style="width: @Model.BlockProgress[@block.Id]%"></div>
                                </div>
                                <div class="block-progress-text">@Model.BlockProgress[@block.Id]@T["Index_CompletedSuffix"]</div>
                            </div>
                        </article>
                    </a>
                }
            </section>

            <footer class="bottom-bar">
                <form method="post" asp-page-handler="Logout">
                    <button type="submit" class="btn-logout">@T["Index_Logout"]</button>
                </form>
            </footer>

        </div>
    </div>

    <script>
        // Init theme icon on load
        const btn = document.getElementById('theme-btn');
        btn.textContent = localStorage.getItem('theme') === 'dark' ? '☀️' : '🌙';

        function toggleTheme() {
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            document.documentElement.setAttribute('data-theme', isDark ? 'light' : 'dark');
            localStorage.setItem('theme', isDark ? 'light' : 'dark');
            btn.textContent = isDark ? '🌙' : '☀️';
        }

        function toggleLang(e) {
            e.stopPropagation();
            document.getElementById('lang-dropdown').classList.toggle('open');
        }
        document.addEventListener('click', function() {
            document.getElementById('lang-dropdown').classList.remove('open');
        });
    </script>
</body>
</html>
