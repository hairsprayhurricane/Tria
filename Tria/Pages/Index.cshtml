@page
@model IndexModel
@{
    ViewData["Title"] = "Дашборд";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>Дашборд – Tria</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background-color: #f3f4f6;
            color: #111827;
        }
        .page {
            min-height: 100vh;
            padding: 24px;
        }
        .shell {
            max-width: 1200px;
            margin: 0 auto;
        }

        /* Верхняя панель */
        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }
        .top-title {
            font-size: 20px;
            font-weight: 600;
            color: #111827;
        }
        .top-subtitle {
            font-size: 12px;
            color: #6b7280;
        }

        /* Карточка прогресса */
        .summary-box {
            background-color: #ffffff;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            padding: 16px 18px;
            margin-bottom: 18px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .summary-text {
            font-size: 14px;
            color: #4b5563;
        }
        .summary-badge {
            padding: 6px 10px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 600;
        }
        .summary-badge-ok {
            background-color: #dcfce7;
            color: #15803d;
            border: 1px solid #15803d;
        }
        .summary-badge-progress {
            background-color: #e5e7eb;
            color: #374151;
            border: 1px solid #9ca3af;
        }

        /* Сетка блоков */
        .blocks-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 18px;
        }
        .block-link {
            text-decoration: none;
            color: inherit;
        }
        .block-card {
            background-color: #ffffff;
            border-radius: 8px;
            border: 1px solid #d1d5db;
            box-shadow: 0 8px 20px rgba(0,0,0,0.05);
            transition: transform 0.18s ease, box-shadow 0.18s ease;
            cursor: pointer;
        }
        .block-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.08);
        }
        .block-header {
            padding: 14px 16px;
            border-bottom: 1px solid #e5e7eb;
            background-color: #f9fafb;
        }
        .block-title {
            font-size: 15px;
            font-weight: 600;
            color: #111827;
            margin-bottom: 4px;
        }
        .block-badge {
            font-size: 11px;
            color: #6b7280;
        }
        .block-body {
            padding: 14px 16px 16px 16px;
        }
        .block-desc {
            font-size: 13px;
            color: #4b5563;
            margin-bottom: 10px;
        }
        .progress-bar-bg {
            width: 100%;
            height: 8px;
            border-radius: 999px;
            background-color: #e5e7eb;
            overflow: hidden;
            margin-bottom: 6px;
        }
        .progress-bar-fill {
            height: 100%;
            border-radius: 999px;
            background-color: #2563eb; /* обычный синий */
            transition: width 0.4s ease;
        }
        .block-progress-text {
            font-size: 12px;
            color: #374151;
            text-align: right;
        }

        /* Низ */
        .bottom-bar {
            margin-top: 24px;
            display: flex;
            justify-content: flex-end;
        }
        .btn-logout {
            padding: 8px 18px;
            font-size: 13px;
            border-radius: 4px;
            border: 1px solid #b91c1c;
            background-color: #b91c1c;
            color: #f9fafb;
            cursor: pointer;
        }
        .btn-logout:hover {
            background-color: #991b1b;
        }
    </style>
</head>
<body>
    <div class="page">
        <div class="shell">

            <header class="top-bar">
                <div>
                    <div class="top-title">Tria · Дашборд</div>
                    <div class="top-subtitle">Обучение кибербезопасности, версия 1.0</div>
                </div>
            </header>

            <section class="summary-box">
                <div class="summary-text">
                    Общий прогресс по курсу: <b>@Model.OverallProgress%</b>
                </div>

                @if (Model.OverallProgress >= 80)
                {
                    <div class="summary-badge summary-badge-ok">
                        Сертификация достигнута
                    </div>
                }
                else
                {
                    <div class="summary-badge summary-badge-progress">
                        В процессе обучения
                    </div>
                }
            </section>

            <section class="blocks-grid">
                @foreach (var block in Model.Blocks)
                {
                    <a href="/Blocks/@block.Id" class="block-link">
                        <article class="block-card">
                            <div class="block-header">
                                <div class="block-title">@block.Title</div>
                                <div class="block-badge">@block.Description</div>
                            </div>
                            <div class="block-body">
                                <p class="block-desc">
                                    Практика и теория для отработки навыков.
                                </p>

                                <div class="progress-bar-bg">
                                    <div class="progress-bar-fill"
                                         style="width: @Model.BlockProgress[@block.Id]%"></div>
                                </div>
                                <div class="block-progress-text">
                                    @Model.BlockProgress[@block.Id]% завершено
                                </div>
                            </div>
                        </article>
                    </a>
                }
            </section>

            <footer class="bottom-bar">
                <form method="post" asp-page-handler="Logout">
                    <button type="submit" class="btn-logout">
                        Выйти из системы
                    </button>
                </form>
            </footer>

        </div>
    </div>
</body>
</html>
