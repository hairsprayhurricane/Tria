@page "/Blocks/{blockId}"
@model BlocksIndexModel
@using Tria.Services
@inject IUiLocalizer T
@{
    ViewData["Title"] = Model.Block?.Title ?? "Block";
    Layout = null;
    var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}

<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <script>(function(){ if(localStorage.getItem("theme")==="dark") document.documentElement.setAttribute("data-theme","dark"); })();</script>
    <title>@ViewData["Title"] – Tria</title>
    <style>
        :root { --bg:#f3f4f6; --surface:#ffffff; --surface-2:#f9fafb; --border:#d1d5db; --border-2:#e5e7eb; --text:#111827; --text-muted:#6b7280; --text-sub:#4b5563; --text-light:#374151; --progress-bg:#e5e7eb; --shadow:rgba(0,0,0,0.06); }
        [data-theme="dark"] { --bg:#0f1117; --surface:#1a1d2e; --surface-2:#151826; --border:#2a2d3e; --border-2:#222536; --text:#f1f5f9; --text-muted:#94a3b8; --text-sub:#cbd5e1; --text-light:#e2e8f0; --progress-bg:#2a2d3e; --shadow:rgba(0,0,0,0.4); }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background-color: var(--bg); color: var(--text); transition: background-color 0.3s, color 0.3s; }
        .page { min-height: 100vh; padding: 24px; }
        .shell { max-width: 900px; margin: 0 auto; }

        .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
        .theme-btn {
            width: 34px; height: 34px; border: 1px solid var(--border); border-radius: 6px;
            background: var(--surface); cursor: pointer; font-size: 16px;
            display: flex; align-items: center; justify-content: center;
            transition: border-color 0.2s, background-color 0.3s;
        }
        .theme-btn:hover { border-color: var(--text-muted); }

        .back-link { display: inline-block; font-size: 13px; color: #2563eb; text-decoration: none; }
        .back-link:hover { text-decoration: underline; }
        .block-shell { background-color: var(--surface); border-radius: 8px; border: 1px solid var(--border); box-shadow: 0 10px 24px var(--shadow); margin-bottom: 20px; transition: background-color 0.3s, border-color 0.3s; }
        .block-main-header { padding: 18px 20px; border-bottom: 1px solid var(--border-2); background-color: var(--surface-2); transition: background-color 0.3s, border-color 0.3s; }
        .block-main-title { font-size: 20px; font-weight: 600; margin-bottom: 4px; }
        .block-main-desc { font-size: 13px; color: var(--text-sub); }
        .block-main-body { padding: 18px 20px 20px; }
        .progress-bar-bg { width: 100%; height: 10px; border-radius: 999px; background-color: var(--progress-bg); overflow: hidden; margin-bottom: 6px; transition: background-color 0.3s; }
        .progress-bar-fill { height: 100%; border-radius: 999px; background-color: #2563eb; transition: width 0.4s; }
        .progress-text { font-size: 13px; color: var(--text-light); text-align: right; }
        .modules-title { font-size: 16px; font-weight: 600; color: var(--text); margin-bottom: 10px; }
        .modules-list { display: grid; gap: 10px; }
        .module-link { text-decoration: none; color: inherit; }
        .module-row { background-color: var(--surface); border-radius: 6px; border: 1px solid var(--border); padding: 12px 14px; display: flex; align-items: center; justify-content: space-between; transition: background-color 0.15s, border-color 0.15s; }
        .module-row:hover { background-color: var(--surface-2); border-color: var(--text-muted); }
        .module-left { display: flex; align-items: center; gap: 10px; }
        .module-icon { font-size: 20px; }
        .module-title { font-size: 14px; font-weight: 500; }
        .module-status { font-size: 12px; }
        .status-done { color: #15803d; }
        .status-pending { color: #b45309; }
        .module-arrow { font-size: 16px; color: var(--text-muted); }
        .empty-box { background-color: var(--surface); border-radius: 6px; border: 1px solid var(--border); padding: 20px; text-align: center; color: var(--text-sub); font-size: 14px; }

        /* Кнопка игры */
        .game-banner {
            display: flex; align-items: center; justify-content: space-between;
            background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
            border-radius: 8px; border: 1px solid #4338ca;
            padding: 16px 20px; margin-bottom: 20px;
            box-shadow: 0 4px 16px rgba(99,102,241,0.25);
        }
        .game-banner.locked {
            background: var(--surface-2);
            border-color: var(--border);
            box-shadow: none;
        }
        .game-banner-text { color: #e0e7ff; }
        .game-banner.locked .game-banner-text { color: var(--text-muted); }
        .game-banner-title { font-size: 15px; font-weight: 600; margin-bottom: 2px; }
        .game-banner-sub { font-size: 12px; color: #a5b4fc; }
        .game-banner.locked .game-banner-sub { color: var(--text-muted); }
        .btn-game {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 9px 20px; font-size: 14px; font-weight: 500;
            border-radius: 6px; border: none;
            background: #4f46e5; color: #fff;
            text-decoration: none; cursor: pointer;
            transition: background 0.2s, transform 0.1s;
            white-space: nowrap;
        }
        .btn-game:hover { background: #4338ca; transform: translateY(-1px); }
        .btn-game:active { transform: translateY(0); }
        .btn-game-locked {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 9px 20px; font-size: 14px; font-weight: 500;
            border-radius: 6px; border: 1px solid var(--border);
            background: var(--surface); color: var(--text-muted);
            cursor: not-allowed; white-space: nowrap;
        }
    </style>
</head>
<body>
    <div class="page">
        <div class="shell">

            <div class="top-bar">
                <a href="/" class="back-link">@T["Blocks_Back"]</a>
                <button type="button" class="theme-btn" id="theme-btn" onclick="toggleTheme()">🌙</button>
            </div>

            @if (Model.Block != null)
            {
                <section class="block-shell">
                    <header class="block-main-header">
                        <div class="block-main-title">@Model.Block.Title</div>
                        <div class="block-main-desc">@Model.Block.Description</div>
                    </header>
                    <div class="block-main-body">
                        <div class="progress-bar-bg">
                            <div class="progress-bar-fill" style="width: @Model.Progress%"></div>
                        </div>
                        <div class="progress-text">@Model.Progress@T["Index_CompletedSuffix"]</div>
                    </div>
                </section>

                @* Баннер с кнопкой игры — показывается только если HasGame=true *@
                @if (Model.HasGame)
                {
                    @if (Model.GameUnlocked)
                    {
                        <div class="game-banner">
                            <div class="game-banner-text">
                                <div class="game-banner-title">🎮 @T["Blocks_GameTitle"]</div>
                                <div class="game-banner-sub">@T["Blocks_GameSub"]</div>
                            </div>
                            <a href="@Model.GameUrl" class="btn-game">
                                ▶ @T["Blocks_GameBtn"]
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="game-banner locked">
                            <div class="game-banner-text">
                                <div class="game-banner-title">🔒 @T["Blocks_GameTitle"]</div>
                                <div class="game-banner-sub">@T["Blocks_GameLocked"]</div>
                            </div>
                            <span class="btn-game-locked">
                                🔒 @T["Blocks_GameBtn"]
                            </span>
                        </div>
                    }
                }

                <section>
                    <div class="modules-title">@T["Blocks_Modules"]</div>
                    @if (Model.Modules.Any())
                    {
                        <div class="modules-list">
                            @foreach (var module in Model.Modules)
                            {
                                var url = module.Type == "Video" ? $"/Modules/video/{module.Id}"
                                        : module.Type == "Game"  ? $"/Modules/game/{module.Id}"
                                        :                          $"/Modules/quiz/{module.Id}";

                                var icon = module.Type == "Video" ? "▶️"
                                         : module.Type == "Quiz"  ? "📝"
                                         : module.Type == "Game"  ? "🎮"
                                         : "🧪";

                                <a href="@url" class="module-link">
                                    <div class="module-row">
                                        <div class="module-left">
                                            <div class="module-icon">@icon</div>
                                            <div class="module-title">@module.Title</div>
                                        </div>
                                        <div>
                                            @if (Model.CompletedModules.Contains((int)module.Id))
                                            {
                                                <span class="module-status status-done">@T["Blocks_Done"]</span>
                                            }
                                            else
                                            {
                                                <span class="module-status status-pending">@T["Blocks_Pending"]</span>
                                            }
                                        </div>
                                        <div class="module-arrow">→</div>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-box">@T["Blocks_Empty"]</div>
                    }
                </section>
            }
            else
            {
                <div class="empty-box">@T["Blocks_NotFound"]</div>
            }

        </div>
    </div>
    <script>
        const btn = document.getElementById('theme-btn');
        btn.textContent = localStorage.getItem('theme') === 'dark' ? '☀️' : '🌙';
        function toggleTheme() {
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            document.documentElement.setAttribute('data-theme', isDark ? 'light' : 'dark');
            localStorage.setItem('theme', isDark ? 'light' : 'dark');
            btn.textContent = isDark ? '🌙' : '☀️';
        }
    </script>
</body>
</html>
