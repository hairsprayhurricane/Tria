@page "/Lesson/{lessonId:int}/Materials"
@model Tria.Pages.Lessons.LessonMaterialsModel
@using Tria.Services
@inject IUiLocalizer T
@{
    ViewData["Title"] = "Материалы: " + (Model.Lesson?.Title ?? "");
    Layout = null;
    var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}
<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script>(function(){ if(localStorage.getItem("theme")==="dark") document.documentElement.setAttribute("data-theme","dark"); })();</script>
    <title>@ViewData["Title"] – Tria</title>
    <style>
        :root { --bg:#f3f4f6; --surface:#ffffff; --surface-2:#f9fafb; --border:#d1d5db; --border-2:#e5e7eb; --text:#111827; --text-muted:#6b7280; --text-sub:#4b5563; --shadow:rgba(0,0,0,0.06); --accent:#2563eb; --accent-h:#1d4ed8; }
        [data-theme="dark"] { --bg:#0f1117; --surface:#1a1d2e; --surface-2:#151826; --border:#2a2d3e; --border-2:#222536; --text:#f1f5f9; --text-muted:#94a3b8; --text-sub:#cbd5e1; --shadow:rgba(0,0,0,0.4); }
        * { box-sizing:border-box; margin:0; padding:0; }
        body { font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:var(--bg); color:var(--text); transition:background-color 0.3s,color 0.3s; }
        a { color:var(--accent); text-decoration:none; }
        .page { min-height:100vh; padding:24px; }
        .shell { max-width:700px; margin:0 auto; }
        .top-bar { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; gap:12px; flex-wrap:wrap; }
        .breadcrumbs { display:flex; gap:8px; align-items:center; font-size:14px; color:var(--text-muted); flex-wrap:wrap; }
        .breadcrumbs a { color:var(--text-muted); }
        .breadcrumbs a:hover { color:var(--text); }
        .breadcrumbs span.cur { color:var(--text); font-weight:500; }
        .theme-btn { width:34px; height:34px; border:1px solid var(--border); border-radius:6px; background:var(--surface); cursor:pointer; font-size:16px; display:flex; align-items:center; justify-content:center; transition:border-color 0.2s,background-color 0.3s; }
        .theme-btn:hover { border-color:var(--text-muted); }
        .page-header { margin-bottom:24px; }
        .page-header h1 { font-size:22px; font-weight:700; }

        .mat-list { display:flex; flex-direction:column; gap:10px; margin-bottom:20px; }
        .mat-btn { display:flex; align-items:center; gap:14px; padding:14px 18px; background:var(--surface); border:1px solid var(--border); border-radius:10px; text-decoration:none; color:var(--text); transition:border-color 0.2s, box-shadow 0.15s; }
        .mat-btn:hover { border-color:var(--accent); box-shadow:0 2px 8px var(--shadow); text-decoration:none; color:var(--text); }
        .mat-icon { font-size:22px; width:32px; text-align:center; flex-shrink:0; }
        .mat-body { flex:1; }
        .mat-title { font-size:15px; font-weight:600; }
        .mat-type { font-size:12px; color:var(--text-muted); margin-top:2px; }
        .mat-arrow { font-size:16px; color:var(--text-muted); flex-shrink:0; }

        .divider { border:none; border-top:1px solid var(--border-2); margin:20px 0; }
        .btn-primary { display:inline-block; padding:10px 20px; background:var(--accent); color:#fff; border:none; border-radius:8px; font-size:14px; font-weight:600; cursor:pointer; text-decoration:none; transition:background 0.2s; }
        .btn-primary:hover { background:var(--accent-h); text-decoration:none; color:#fff; }
        .success-msg { display:flex; align-items:center; gap:8px; font-size:14px; font-weight:600; color:#065f46; background:#d1fae5; padding:10px 16px; border-radius:8px; }
        [data-theme="dark"] .success-msg { background:#064e3b; color:#6ee7b7; }
        .completion-box { background:var(--surface); border:1px solid var(--border); border-radius:10px; padding:18px 20px; }
    </style>
</head>
<body>
<div class="page">
    <div class="shell">

        <div class="top-bar">
            <div class="breadcrumbs">
                <a href="/Dashboard">Дашборд</a>
                <span>/</span>
                @if (Model.Course != null)
                {
                    <a href="/Course/@Model.Course.Id">@Model.Course.Title</a>
                    <span>/</span>
                }
                @if (Model.Module != null)
                {
                    <a href="/Module/@Model.Module.Id">@Model.Module.Title</a>
                    <span>/</span>
                }
                @if (Model.Lesson != null)
                {
                    <a href="/Lesson/@Model.Lesson.Id">@Model.Lesson.Title</a>
                    <span>/</span>
                }
                <span class="cur">Материалы</span>
            </div>
            <button type="button" class="theme-btn" id="theme-btn" onclick="toggleTheme()">🌙</button>
        </div>

        @if (Model.Lesson == null)
        {
            <p style="color:var(--text-muted)">Урок не найден.</p>
        }
        else
        {
            <div class="page-header">
                <h1>📚 Материалы урока</h1>
            </div>

            <div class="mat-list">
                @for (int i = 0; i < Model.Lesson.Materials.Count; i++)
                {
                    var mat = Model.Lesson.Materials[i];

                    @if (mat.Type == "Video" && mat.YoutubeId != null)
                    {
                        <a href="/Lesson/@Model.Lesson.Id/Video/@i" class="mat-btn">
                            <span class="mat-icon">▶️</span>
                            <span class="mat-body">
                                <span class="mat-title">@mat.Title</span>
                                <span class="mat-type">Видео · YouTube</span>
                            </span>
                            <span class="mat-arrow">›</span>
                        </a>
                    }
                    else if (mat.Type == "PDF" && mat.FilePath != null)
                    {
                        <a href="@mat.FilePath" target="_blank" class="mat-btn">
                            <span class="mat-icon">📄</span>
                            <span class="mat-body">
                                <span class="mat-title">@mat.Title</span>
                                <span class="mat-type">Документ · PDF</span>
                            </span>
                            <span class="mat-arrow">↗</span>
                        </a>
                    }
                    else if (mat.Type == "Image" && mat.FilePath != null)
                    {
                        <a href="@mat.FilePath" target="_blank" class="mat-btn">
                            <span class="mat-icon">🖼️</span>
                            <span class="mat-body">
                                <span class="mat-title">@mat.Title</span>
                                <span class="mat-type">Изображение</span>
                            </span>
                            <span class="mat-arrow">↗</span>
                        </a>
                    }
                }
            </div>

            <div class="completion-box">
                @if (Model.Progress?.MaterialsCompleted == true)
                {
                    <div class="success-msg">✅ Материалы пройдены (+@Model.Lesson.XpReward XP)</div>
                }
                else
                {
                    <form method="post" action="/Lesson/@Model.Lesson.Id/Materials?handler=CompleteMaterials">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-primary">Материалы пройдены (+@Model.Lesson.XpReward XP)</button>
                    </form>
                }
            </div>
        }

    </div>
</div>
<script>
    var btn = document.getElementById("theme-btn");
    btn.textContent = localStorage.getItem("theme") === "dark" ? "☀️" : "🌙";
    function toggleTheme() {
        var d = document.documentElement.getAttribute("data-theme") === "dark";
        document.documentElement.setAttribute("data-theme", d ? "light" : "dark");
        localStorage.setItem("theme", d ? "light" : "dark");
        btn.textContent = d ? "🌙" : "☀️";
    }
</script>
</body>
</html>
