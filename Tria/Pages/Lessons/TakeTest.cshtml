@page "/Lesson/{lessonId:int}/Test"
@model Tria.Pages.Lessons.TakeTestModel
@using Tria.Services
@using Tria.Models
@inject IUiLocalizer T
@{
    ViewData["Title"] = "Тест: " + (Model.Lesson?.Title ?? "");
    Layout = null;
    var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    bool showForm = Model.LatestAttempt == null || Request.Query["retake"] == "1";
    int lessonId = int.TryParse(RouteData.Values["lessonId"]?.ToString(), out var lid) ? lid : 0;
}
<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script>(function(){ if(localStorage.getItem("theme")==="dark") document.documentElement.setAttribute("data-theme","dark"); })();</script>
    <title>@ViewData["Title"] – Tria</title>
    <style>
        :root { --bg:#f3f4f6; --surface:#ffffff; --surface-2:#f9fafb; --border:#d1d5db; --border-2:#e5e7eb; --text:#111827; --text-muted:#6b7280; --text-sub:#4b5563; --progress-bg:#e5e7eb; --shadow:rgba(0,0,0,0.06); --accent:#2563eb; --accent-h:#1d4ed8; }
        [data-theme="dark"] { --bg:#0f1117; --surface:#1a1d2e; --surface-2:#151826; --border:#2a2d3e; --border-2:#222536; --text:#f1f5f9; --text-muted:#94a3b8; --text-sub:#cbd5e1; --progress-bg:#2a2d3e; --shadow:rgba(0,0,0,0.4); }
        * { box-sizing:border-box; margin:0; padding:0; }
        body { font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:var(--bg); color:var(--text); transition:background-color 0.3s,color 0.3s; }
        a { color:var(--accent); text-decoration:none; }
        a:hover { text-decoration:underline; }
        .page { min-height:100vh; padding:24px; }
        .shell { max-width:860px; margin:0 auto; }
        .top-bar { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; gap:12px; flex-wrap:wrap; }
        .breadcrumbs { display:flex; gap:8px; align-items:center; font-size:14px; color:var(--text-muted); flex-wrap:wrap; }
        .breadcrumbs a { color:var(--text-muted); }
        .breadcrumbs a:hover { color:var(--text); }
        .breadcrumbs span.cur { color:var(--text); font-weight:500; }
        .theme-btn { width:34px; height:34px; border:1px solid var(--border); border-radius:6px; background:var(--surface); cursor:pointer; font-size:16px; display:flex; align-items:center; justify-content:center; transition:border-color 0.2s,background-color 0.3s; }
        .theme-btn:hover { border-color:var(--text-muted); }
        .page-header { margin-bottom:24px; }
        .page-header h1 { font-size:22px; font-weight:700; }
        .section { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:22px; margin-bottom:16px; }
        .result-summary { display:flex; align-items:center; gap:16px; flex-wrap:wrap; margin-bottom:20px; padding:16px; background:var(--surface-2); border:1px solid var(--border-2); border-radius:10px; }
        .result-score { font-size:32px; font-weight:700; color:var(--accent); }
        .result-label { font-size:14px; color:var(--text-muted); }
        .question-block { border:1px solid var(--border-2); border-radius:10px; padding:18px; margin-bottom:14px; background:var(--surface-2); }
        .question-block:last-child { margin-bottom:0; }
        .question-num { font-size:12px; color:var(--text-muted); font-weight:600; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.04em; }
        .question-text { font-size:15px; font-weight:500; margin-bottom:14px; line-height:1.5; }
        .options-list { list-style:none; display:flex; flex-direction:column; gap:8px; }
        .option-label { display:flex; align-items:flex-start; gap:10px; cursor:pointer; padding:10px 14px; border:1px solid var(--border-2); border-radius:8px; transition:border-color 0.2s,background-color 0.2s; font-size:14px; }
        .option-label:hover { border-color:var(--accent); background:var(--surface); }
        .option-label input[type=radio] { margin-top:2px; flex-shrink:0; accent-color:var(--accent); }
        .textarea-ans { width:100%; min-height:90px; padding:10px; background:var(--surface); border:1px solid var(--border); border-radius:8px; color:var(--text); font-family:inherit; font-size:14px; resize:vertical; transition:border-color 0.2s; }
        .textarea-ans:focus { outline:none; border-color:var(--accent); }
        .sa-note { font-size:12px; color:var(--text-muted); margin-top:6px; font-style:italic; }
        .btn-primary { padding:10px 22px; background:var(--accent); color:#fff; border:none; border-radius:8px; font-size:14px; font-weight:600; cursor:pointer; transition:background 0.2s; text-decoration:none; display:inline-block; }
        .btn-primary:hover { background:var(--accent-h); color:#fff; text-decoration:none; }
        .btn-secondary { display:inline-block; padding:10px 22px; background:var(--surface-2); color:var(--text); border:1px solid var(--border); border-radius:8px; font-size:14px; font-weight:600; text-decoration:none; transition:border-color 0.2s; }
        .btn-secondary:hover { border-color:var(--accent); text-decoration:none; color:var(--text); }
        .ans-correct { color:#065f46; font-weight:500; }
        .ans-wrong   { color:#991b1b; font-weight:500; }
        [data-theme="dark"] .ans-correct { color:#6ee7b7; }
        [data-theme="dark"] .ans-wrong   { color:#fca5a5; }
        .ans-row { display:flex; flex-direction:column; gap:5px; font-size:14px; }
        .ans-checking { color:var(--text-muted); font-style:italic; font-size:13px; }
        .ai-comment { margin-top:6px; padding:8px 12px; background:var(--surface-2); border-left:3px solid var(--accent); border-radius:0 6px 6px 0; font-size:13px; color:var(--text-sub); line-height:1.5; }
        .pass-badge { display:inline-block; padding:4px 12px; border-radius:99px; font-size:13px; font-weight:600; }
        .pass-badge-passed { background:#d1fae5; color:#065f46; }
        .pass-badge-failed { background:#fee2e2; color:#991b1b; }
        [data-theme="dark"] .pass-badge-passed { background:#064e3b; color:#6ee7b7; }
        [data-theme="dark"] .pass-badge-failed { background:#7f1d1d; color:#fca5a5; }
        .action-row { display:flex; gap:12px; flex-wrap:wrap; align-items:center; margin-top:20px; }
    </style>
</head>
<body>
<div class="page">
    <div class="shell">

        <div class="top-bar">
            <div class="breadcrumbs">
                <a href="/Dashboard">Дашборд</a>
                <span>/</span>
                @if (Model.Course != null)
                {
                    <a href="/Course/@Model.Course.Id">@Model.Course.Title</a>
                    <span>/</span>
                }
                @if (Model.Module != null)
                {
                    <a href="/Module/@Model.Module.Id">@Model.Module.Title</a>
                    <span>/</span>
                }
                @if (Model.Lesson != null)
                {
                    <a href="/Lesson/@Model.Lesson.Id">@Model.Lesson.Title</a>
                    <span>/</span>
                }
                <span class="cur">Тест</span>
            </div>
            <button type="button" class="theme-btn" id="theme-btn" onclick="toggleTheme()">🌙</button>
        </div>

        @if (Model.Lesson == null || Model.Lesson.Test == null)
        {
            <p style="color:var(--text-muted)">Тест не найден.</p>
        }
        else if (!showForm && Model.LatestAttempt != null)
        {
            @* ── Results view ── *@
            <div class="page-header">
                <h1>Результаты теста</h1>
            </div>

            <div class="section">
                <div class="result-summary">
                    @if (Model.LatestAttempt.Status == TestStatus.Checking)
                    {
                        <div class="result-score" style="color:var(--text-muted)">?%</div>
                    }
                    else
                    {
                        <div class="result-score">@Model.LatestAttempt.ScorePercent%</div>
                    }
                    <div>
                        <div class="result-label">
                            @if (Model.LatestAttempt.Status == TestStatus.Checking)
                            {
                                <span>Ответы на проверке</span>
                            }
                            else
                            {
                                <span>@Model.LatestAttempt.Score из @Model.LatestAttempt.MaxScore баллов</span>
                            }
                        </div>
                        @if (Model.LatestAttempt.Status == TestStatus.Passed)
                        {
                            <span class="pass-badge pass-badge-passed">✅ Тест сдан</span>
                        }
                        else if (Model.LatestAttempt.Status == TestStatus.Failed)
                        {
                            <span class="pass-badge pass-badge-failed">❌ Тест не сдан</span>
                        }
                        else
                        {
                            <span class="pass-badge" style="background:var(--surface-2);color:var(--text-muted);">⏳ На проверке</span>
                        }
                    </div>
                </div>

                @{
                    var savedAnswers = Model.LatestAttempt.GetAnswers();
                    var questions    = Model.Lesson.Test.Questions;
                }

                @for (int i = 0; i < questions.Count; i++)
                {
                    var q   = questions[i];
                    var ans = savedAnswers.FirstOrDefault(a => a.QuestionIndex == i);
                    <div class="question-block">
                        <div class="question-num">Вопрос @(i + 1)</div>
                        <div class="question-text">@q.Text</div>
                        @if (q.Type == "MultipleChoice")
                        {
                            <div class="ans-row">
                                <div>Ваш ответ:
                                    @if (ans?.SelectedOptionIndex >= 0 && ans.SelectedOptionIndex < q.Options.Count)
                                    {
                                        <span class="@(ans.IsCorrect ? "ans-correct" : "ans-wrong")">@q.Options[(int)ans.SelectedOptionIndex!]</span>
                                    }
                                    else
                                    {
                                        <span style="color:var(--text-muted)">Нет ответа</span>
                                    }
                                </div>
                                @if (ans != null && !ans.IsCorrect)
                                {
                                    <div>Правильный ответ: <span class="ans-correct">@q.Options[q.CorrectOptionIndex]</span></div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="ans-row">
                                <div>Ваш ответ: <span style="color:var(--text-sub)">@(ans?.TextAnswer ?? "—")</span></div>
                                @if (ans?.AiCheckedAt == null)
                                {
                                    <div class="ans-checking">⏳ * Ваш ответ проверяется — результат появится автоматически *</div>
                                }
                                else
                                {
                                    <div class="@(ans.IsCorrect ? "ans-correct" : "ans-wrong")">@(ans.IsCorrect ? "✓ Верно" : "✗ Неверно")</div>
                                    @if (!string.IsNullOrEmpty(ans.AiComment))
                                    {
                                        <div class="ai-comment">💬 @ans.AiComment</div>
                                    }
                                }
                            </div>
                        }
                    </div>
                }

                <div class="action-row">
                    <a href="/Lesson/@Model.Lesson.Id" class="btn-secondary">← Назад к уроку</a>
                    @if (Model.LatestAttempt.Status == TestStatus.Failed)
                    {
                        <a href="/Lesson/@Model.Lesson.Id/Test?retake=1" class="btn-primary">Пересдать</a>
                    }
                </div>
            </div>
        }
        else
        {
            @* ── Test form ── *@
            <div class="page-header">
                <h1>📝 @Model.Lesson.Title</h1>
            </div>

            <form method="post" action="/Lesson/@Model.Lesson.Id/Test">
                @Html.AntiForgeryToken()

                @for (int i = 0; i < Model.Lesson.Test.Questions.Count; i++)
                {
                    var q = Model.Lesson.Test.Questions[i];
                    <div class="section">
                        <div class="question-num">Вопрос @(i + 1) из @Model.Lesson.Test.Questions.Count</div>
                        <div class="question-text">@q.Text</div>
                        @if (q.Type == "MultipleChoice")
                        {
                            <ul class="options-list">
                                @for (int j = 0; j < q.Options.Count; j++)
                                {
                                    <li>
                                        <label class="option-label">
                                            <input type="radio" name="q_@i" value="@j" />
                                            @q.Options[j]
                                        </label>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <textarea name="q_@(i)_text" class="textarea-ans" placeholder="Введите ваш ответ..."></textarea>
                            <div class="sa-note">Этот вопрос будет автоматически проверен ИИ после отправки.</div>
                        }
                    </div>
                }

                <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center;">
                    <button type="submit" class="btn-primary">Отправить тест</button>
                    <a href="/Lesson/@Model.Lesson.Id" class="btn-secondary">Отмена</a>
                </div>
            </form>
        }

    </div>
</div>
<script>
    var btn = document.getElementById("theme-btn");
    btn.textContent = localStorage.getItem("theme") === "dark" ? "☀️" : "🌙";
    function toggleTheme() {
        var d = document.documentElement.getAttribute("data-theme") === "dark";
        document.documentElement.setAttribute("data-theme", d ? "light" : "dark");
        localStorage.setItem("theme", d ? "light" : "dark");
        btn.textContent = d ? "🌙" : "☀️";
    }
</script>
</body>
</html>
