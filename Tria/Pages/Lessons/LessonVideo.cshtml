@page "/Lesson/{lessonId:int}/Video/{materialIndex:int}"
@model Tria.Pages.Lessons.LessonVideoModel
@using Tria.Services
@inject IUiLocalizer T
@{
    ViewData["Title"] = Model.Material?.Title ?? "Видео";
    Layout = null;
    var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}
<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script>(function(){ if(localStorage.getItem("theme")==="dark") document.documentElement.setAttribute("data-theme","dark"); })();</script>
    <title>@ViewData["Title"] – Tria</title>
    <style>
        :root { --bg:#f3f4f6; --surface:#ffffff; --surface-2:#f9fafb; --border:#d1d5db; --border-2:#e5e7eb; --text:#111827; --text-muted:#6b7280; --shadow:rgba(0,0,0,0.06); --accent:#2563eb; --accent-h:#1d4ed8; }
        [data-theme="dark"] { --bg:#0f1117; --surface:#1a1d2e; --surface-2:#151826; --border:#2a2d3e; --border-2:#222536; --text:#f1f5f9; --text-muted:#94a3b8; --shadow:rgba(0,0,0,0.4); }
        * { box-sizing:border-box; margin:0; padding:0; }
        body { font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:var(--bg); color:var(--text); transition:background-color 0.3s,color 0.3s; }
        a { color:var(--accent); text-decoration:none; }
        .page { min-height:100vh; padding:24px; }
        .shell { max-width:900px; margin:0 auto; }
        .top-bar { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; gap:12px; flex-wrap:wrap; }
        .breadcrumbs { display:flex; gap:8px; align-items:center; font-size:14px; color:var(--text-muted); flex-wrap:wrap; }
        .breadcrumbs a { color:var(--text-muted); }
        .breadcrumbs a:hover { color:var(--text); }
        .breadcrumbs span.cur { color:var(--text); font-weight:500; }
        .theme-btn { width:34px; height:34px; border:1px solid var(--border); border-radius:6px; background:var(--surface); cursor:pointer; font-size:16px; display:flex; align-items:center; justify-content:center; transition:border-color 0.2s,background-color 0.3s; }
        .theme-btn:hover { border-color:var(--text-muted); }
        .video-title { font-size:20px; font-weight:700; margin-bottom:18px; }
        .video-wrap { position:relative; padding-bottom:56.25%; height:0; overflow:hidden; border-radius:12px; background:#000; box-shadow:0 4px 24px var(--shadow); }
        .video-wrap iframe { position:absolute; top:0; left:0; width:100%; height:100%; border:none; border-radius:12px; }
        .back-link { display:inline-flex; align-items:center; gap:6px; margin-top:20px; font-size:14px; color:var(--text-muted); }
        .back-link:hover { color:var(--text); text-decoration:none; }
    </style>
</head>
<body>
<div class="page">
    <div class="shell">

        <div class="top-bar">
            <div class="breadcrumbs">
                <a href="/Dashboard">Дашборд</a>
                <span>/</span>
                @if (Model.Course != null)
                {
                    <a href="/Course/@Model.Course.Id">@Model.Course.Title</a>
                    <span>/</span>
                }
                @if (Model.Module != null)
                {
                    <a href="/Module/@Model.Module.Id">@Model.Module.Title</a>
                    <span>/</span>
                }
                @if (Model.Lesson != null)
                {
                    <a href="/Lesson/@Model.Lesson.Id">@Model.Lesson.Title</a>
                    <span>/</span>
                    <a href="/Lesson/@Model.Lesson.Id/Materials">Материалы</a>
                    <span>/</span>
                }
                <span class="cur">@Model.Material?.Title</span>
            </div>
            <button type="button" class="theme-btn" id="theme-btn" onclick="toggleTheme()">🌙</button>
        </div>

        <div class="video-title">▶️ @Model.Material?.Title</div>

        <div class="video-wrap">
            <iframe src="https://www.youtube.com/embed/@Model.Material!.YoutubeId"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen></iframe>
        </div>

        <a href="/Lesson/@Model.Lesson!.Id/Materials" class="back-link">← Назад к материалам</a>

    </div>
</div>
<script>
    var btn = document.getElementById("theme-btn");
    btn.textContent = localStorage.getItem("theme") === "dark" ? "☀️" : "🌙";
    function toggleTheme() {
        var d = document.documentElement.getAttribute("data-theme") === "dark";
        document.documentElement.setAttribute("data-theme", d ? "light" : "dark");
        localStorage.setItem("theme", d ? "light" : "dark");
        btn.textContent = d ? "🌙" : "☀️";
    }
</script>
</body>
</html>
