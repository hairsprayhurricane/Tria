@page
@model Tria.Pages.LoginModel
@{
    ViewData["Title"] = "Вход";
}

<div style="min-height: 100vh; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; padding: 20px;">
    <div style="width: 100%; max-width: 400px; background: white; border-radius: 12px; box-shadow: 0 20px 40px rgba(0,0,0,0.3); overflow: hidden;">

        <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 30px; text-align: center; color: white;">
            <h1 style="margin: 0; font-size: 2em;">🔐 Tria</h1>
            <p style="margin: 10px 0 0 0; opacity: 0.9;">Войдите в систему</p>
        </div>

        <div style="padding: 40px;">
            <div asp-validation-summary="All" style="color: #dc2626; margin-bottom: 15px;"></div>

            <form method="post">
                <div style="margin-bottom: 20px;">
                    <label asp-for="Input.Email" style="display: block; margin-bottom: 8px; font-weight: bold; color: #333;">Email</label>
                    <input asp-for="Input.Email" autocomplete="email"
                           style="width: 100%; padding: 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 1em;" />
                    <span asp-validation-for="Input.Email" style="color: #dc2626; font-size: 0.9em;"></span>
                </div>

                <div style="margin-bottom: 20px;">
                    <label asp-for="Input.Password" style="display: block; margin-bottom: 8px; font-weight: bold; color: #333;">Пароль</label>
                    <input asp-for="Input.Password" autocomplete="current-password"
                           style="width: 100%; padding: 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 1em;" />
                    <span asp-validation-for="Input.Password" style="color: #dc2626; font-size: 0.9em;"></span>
                </div>

                <button type="submit"
                        style="width: 100%; padding: 15px; background: #667eea; color: white; border: none; border-radius: 8px; font-size: 1.1em; font-weight: bold; cursor: pointer;">
                    Войти
                </button>
            </form>

            <div style="margin-top: 24px; text-align: center;">
                <a asp-page="./Register" style="color: #667eea; text-decoration: none; font-weight: bold;">Зарегистрируйтесь</a>
            </div>

            <form method="post" asp-page-handler="Guest"
                  style="margin-top: 20px; padding: 15px; background: #f0f8ff; border-radius: 8px; text-align: center;">
                <button type="submit"
                        style="background: none; border: none; color: #667eea; font-size: 1em; cursor: pointer; text-decoration: underline;">
                    👥 Вход как гость (24 часа)
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
