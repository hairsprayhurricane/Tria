@page "/Progress"
@model Tria.Pages.ProgressModel
@using Tria.Services
@using Tria.Models
@inject IUiLocalizer T
@{
    ViewData["Title"] = "Прогресс";
    Layout = null;
    var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}
<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script>(function(){ if(localStorage.getItem("theme")==="dark") document.documentElement.setAttribute("data-theme","dark"); })();</script>
    <title>@ViewData["Title"] – Tria</title>
    <style>
        :root { --bg:#f3f4f6; --surface:#ffffff; --surface-2:#f9fafb; --border:#d1d5db; --border-2:#e5e7eb; --text:#111827; --text-muted:#6b7280; --text-sub:#4b5563; --progress-bg:#e5e7eb; --shadow:rgba(0,0,0,0.06); --accent:#2563eb; --accent-h:#1d4ed8; }
        [data-theme="dark"] { --bg:#0f1117; --surface:#1a1d2e; --surface-2:#151826; --border:#2a2d3e; --border-2:#222536; --text:#f1f5f9; --text-muted:#94a3b8; --text-sub:#cbd5e1; --progress-bg:#2a2d3e; --shadow:rgba(0,0,0,0.4); }
        * { box-sizing:border-box; margin:0; padding:0; }
        body { font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:var(--bg); color:var(--text); transition:background-color 0.3s,color 0.3s; }
        a { color:var(--accent); text-decoration:none; }
        a:hover { text-decoration:underline; }
        .page { min-height:100vh; padding:24px; }
        .shell { max-width:960px; margin:0 auto; }
        .top-bar { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; gap:12px; flex-wrap:wrap; }
        .breadcrumbs { display:flex; gap:8px; align-items:center; font-size:14px; color:var(--text-muted); }
        .breadcrumbs a { color:var(--text-muted); }
        .breadcrumbs a:hover { color:var(--text); }
        .theme-btn { width:34px; height:34px; border:1px solid var(--border); border-radius:6px; background:var(--surface); cursor:pointer; font-size:16px; display:flex; align-items:center; justify-content:center; transition:border-color 0.2s,background-color 0.3s; }
        .theme-btn:hover { border-color:var(--text-muted); }
        .page-header { margin-bottom:24px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; }
        .page-header h1 { font-size:22px; font-weight:700; }
        .xp-chip { font-size:14px; background:var(--surface); border:1px solid var(--border); border-radius:99px; padding:6px 16px; font-weight:600; color:var(--accent); }
        .courses-list { display:flex; flex-direction:column; gap:16px; }
        .course-card { background:var(--surface); border:1px solid var(--border); border-radius:12px; overflow:hidden; transition:background-color 0.3s; }
        .course-header { padding:18px 20px; cursor:pointer; user-select:none; }
        .course-title-row { display:flex; justify-content:space-between; align-items:center; gap:8px; margin-bottom:10px; }
        .course-title-row span:first-child { font-size:17px; font-weight:600; }
        .expand-icon { font-size:12px; color:var(--text-muted); transition:transform 0.2s; flex-shrink:0; }
        .progress-bar { height:6px; background:var(--progress-bg); border-radius:3px; overflow:hidden; }
        .progress-fill { height:100%; background:var(--accent); border-radius:3px; }
        .progress-label { font-size:12px; color:var(--text-muted); margin-top:4px; }
        .course-body { padding:0 20px 18px; border-top:1px solid var(--border-2); }
        .modules-list { display:flex; flex-direction:column; gap:10px; margin-top:14px; }
        .module-block { background:var(--surface-2); border:1px solid var(--border-2); border-radius:10px; padding:14px 16px; }
        .module-title { font-size:15px; font-weight:600; margin-bottom:8px; }
        .module-bar { height:4px; background:var(--progress-bg); border-radius:2px; overflow:hidden; margin-bottom:4px; }
        .module-fill { height:100%; background:var(--accent); border-radius:2px; }
        .module-pct { font-size:11px; color:var(--text-muted); margin-bottom:10px; }
        .lessons-table { width:100%; border-collapse:collapse; font-size:13px; }
        .lessons-table th { text-align:left; color:var(--text-muted); font-weight:500; padding:4px 8px; border-bottom:1px solid var(--border-2); }
        .lessons-table td { padding:6px 8px; border-bottom:1px solid var(--border-2); vertical-align:middle; }
        .lessons-table tr:last-child td { border-bottom:none; }
        .empty { text-align:center; color:var(--text-muted); padding:60px; font-size:14px; }
    </style>
</head>
<body>
<div class="page">
    <div class="shell">

        <div class="top-bar">
            <div class="breadcrumbs">
                <a href="/Dashboard">Дашборд</a>
                <span>/</span>
                <span style="color:var(--text);font-weight:500;">Прогресс</span>
            </div>
            <button type="button" class="theme-btn" id="theme-btn" onclick="toggleTheme()">🌙</button>
        </div>

        <div class="page-header">
            <h1>Мой прогресс</h1>
            <span class="xp-chip">⚡ @Model.TotalXp XP</span>
        </div>

        @if (!Model.Courses.Any())
        {
            <div class="empty">Нет курсов.</div>
        }
        else
        {
            <div class="courses-list">
                @foreach (var course in Model.Courses)
                {
                    var cpct = Model.CourseProgress.GetValueOrDefault(course.Id, 0);
                    <div class="course-card">
                        <div class="course-header" onclick="toggleCourse(@course.Id)">
                            <div class="course-title-row">
                                <span>@course.Title</span>
                                <span class="expand-icon" id="icon-@course.Id">▼</span>
                            </div>
                            <div class="progress-bar"><div class="progress-fill" style="width:@cpct%"></div></div>
                            <div class="progress-label">Прогресс: @cpct%</div>
                        </div>
                        <div class="course-body" id="course-body-@course.Id">
                            <div class="modules-list">
                                @foreach (var module in course.Modules)
                                {
                                    var mpct = Model.ModuleProgress.GetValueOrDefault(module.Id, 0);
                                    <div class="module-block">
                                        <div class="module-title">@module.Title</div>
                                        <div class="module-bar"><div class="module-fill" style="width:@mpct%"></div></div>
                                        <div class="module-pct">@mpct%</div>
                                        @if (module.Lessons.Any())
                                        {
                                            <table class="lessons-table">
                                                <thead>
                                                    <tr>
                                                        <th>Урок</th>
                                                        <th>Материалы</th>
                                                        <th>Тест</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var lesson in module.Lessons)
                                                    {
                                                        var lp = Model.LessonProgressMap.GetValueOrDefault(lesson.Id);
                                                        var la = Model.LatestAttempts.GetValueOrDefault(lesson.Id);
                                                        string matStatus = lp?.MaterialsCompleted == true ? "✓" : "—";
                                                        string testStatus = la == null ? "—" : la.Status switch
                                                        {
                                                            TestStatus.Passed   => "✅ Сдан",
                                                            TestStatus.Failed   => "❌ Не сдан",
                                                            TestStatus.Checking => "⏳ Проверяется",
                                                            _                   => "—"
                                                        };
                                                        <tr>
                                                            <td><a href="/Lesson/@lesson.Id">@lesson.Title</a></td>
                                                            <td>@matStatus</td>
                                                            <td>@(lesson.Test != null ? testStatus : "н/д")</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

    </div>
</div>
<script>
    var btn = document.getElementById("theme-btn");
    btn.textContent = localStorage.getItem("theme") === "dark" ? "☀️" : "🌙";
    function toggleTheme() {
        var d = document.documentElement.getAttribute("data-theme") === "dark";
        document.documentElement.setAttribute("data-theme", d ? "light" : "dark");
        localStorage.setItem("theme", d ? "light" : "dark");
        btn.textContent = d ? "🌙" : "☀️";
    }
    function toggleCourse(id) {
        var body = document.getElementById("course-body-" + id);
        var icon = document.getElementById("icon-" + id);
        var hidden = body.style.display === "none";
        body.style.display = hidden ? "" : "none";
        icon.style.transform = hidden ? "" : "rotate(-90deg)";
    }
</script>
</body>
</html>
