@page "/Admin/CreateUser"
@model Tria.Pages.Admin.CreateUserModel
@{
    Layout = null;
    var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}
<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script>(function(){ if(localStorage.getItem("theme")==="dark") document.documentElement.setAttribute("data-theme","dark"); })();</script>
    <title>Новый пользователь – Tria Admin</title>
    <style>
        :root { --bg:#f3f4f6; --surface:#ffffff; --surface-2:#f9fafb; --border:#d1d5db; --border-2:#e5e7eb; --text:#111827; --text-muted:#6b7280; --accent:#2563eb; --accent-h:#1d4ed8; --danger:#dc2626; --sidebar-bg:#1c1010; --sidebar-text:#f1e8e8; --sidebar-muted:#b89898; --sidebar-active:#dc2626; --sidebar-hover:rgba(255,255,255,0.06); }
        [data-theme="dark"] { --bg:#0f1117; --surface:#1a1d2e; --surface-2:#151826; --border:#2a2d3e; --border-2:#222536; --text:#f1f5f9; --text-muted:#94a3b8; --sidebar-bg:#110808; }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background: var(--bg); color: var(--text); display: flex; min-height: 100vh; }
        a { color: var(--accent); text-decoration: none; }
        .sidebar { width: 240px; background: var(--sidebar-bg); color: var(--sidebar-text); display: flex; flex-direction: column; padding: 0; flex-shrink: 0; min-height: 100vh; position: sticky; top: 0; height: 100vh; overflow-y: auto; }
        .sidebar-brand { padding: 24px 20px 20px; border-bottom: 1px solid rgba(255,255,255,0.08); }
        .sidebar-brand .logo { font-size: 20px; font-weight: 800; color: #fff; }
        .sidebar-brand .badge { display: inline-block; margin-left: 8px; background: var(--sidebar-active); color: #fff; font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 99px; text-transform: uppercase; letter-spacing: 0.5px; vertical-align: middle; }
        .sidebar-nav { padding: 16px 12px; flex: 1; }
        .nav-section-title { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; color: var(--sidebar-muted); padding: 8px 8px 6px; margin-top: 8px; }
        .nav-item { display: flex; align-items: center; gap: 10px; padding: 9px 10px; border-radius: 8px; color: var(--sidebar-muted); font-size: 14px; font-weight: 500; cursor: pointer; transition: background 0.15s, color 0.15s; text-decoration: none; margin-bottom: 2px; }
        .nav-item:hover { background: var(--sidebar-hover); color: var(--sidebar-text); text-decoration: none; }
        .nav-item.active { background: rgba(220,38,38,0.20); color: #fca5a5; }
        .nav-item .icon { width: 18px; height: 18px; flex-shrink: 0; }
        .sidebar-footer { padding: 16px 12px; border-top: 1px solid rgba(255,255,255,0.08); }
        .user-chip { display: flex; align-items: center; gap: 10px; padding: 8px 10px; }
        .user-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--sidebar-active); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; color: #fff; }
        .user-info { min-width: 0; }
        .user-email { font-size: 12px; color: var(--sidebar-text); font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .user-role { font-size: 11px; color: var(--sidebar-muted); }
        .main { flex: 1; display: flex; flex-direction: column; min-width: 0; }
        .topbar { background: var(--surface); border-bottom: 1px solid var(--border); padding: 0 32px; height: 60px; display: flex; align-items: center; justify-content: space-between; }
        .breadcrumb { display: flex; align-items: center; gap: 6px; font-size: 14px; }
        .breadcrumb a { color: var(--text-muted); }
        .breadcrumb a:hover { color: var(--text); }
        .breadcrumb .sep { color: var(--text-muted); }
        .breadcrumb .current { font-weight: 600; color: var(--text); }
        .theme-btn { width: 34px; height: 34px; border: 1px solid var(--border); border-radius: 6px; background: var(--surface); cursor: pointer; font-size: 16px; display: flex; align-items: center; justify-content: center; }
        .content { padding: 40px 32px; display: flex; justify-content: center; }
        .form-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 32px; width: 100%; max-width: 480px; }
        .form-card h2 { font-size: 18px; font-weight: 700; margin-bottom: 6px; }
        .form-card p { font-size: 13px; color: var(--text-muted); margin-bottom: 28px; }
        .field { margin-bottom: 20px; }
        .field label { display: block; font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 7px; }
        .field input, .field select { width: 100%; padding: 10px 12px; border: 1px solid var(--border); border-radius: 8px; background: var(--surface); color: var(--text); font-size: 14px; outline: none; transition: border-color 0.15s; }
        .field input:focus, .field select:focus { border-color: var(--accent); }
        .field-hint { font-size: 12px; color: var(--text-muted); margin-top: 5px; }
        .error-msg { background: rgba(220,38,38,0.08); border: 1px solid rgba(220,38,38,0.25); border-radius: 8px; padding: 12px 16px; font-size: 13px; color: var(--danger); margin-bottom: 20px; }
        .role-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .role-option { position: relative; }
        .role-option input[type=radio] { position: absolute; opacity: 0; width: 0; height: 0; }
        .role-label { display: block; padding: 12px 16px; border: 2px solid var(--border-2); border-radius: 10px; cursor: pointer; transition: border-color 0.15s, background 0.15s; }
        .role-option input[type=radio]:checked + .role-label { border-color: var(--accent); background: rgba(37,99,235,0.06); }
        .role-name { font-size: 13px; font-weight: 700; color: var(--text); }
        .role-desc { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
        .btn-row { display: flex; gap: 10px; margin-top: 28px; }
        .btn { display: inline-flex; align-items: center; justify-content: center; gap: 6px; padding: 10px 20px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; transition: background 0.15s; text-decoration: none; flex: 1; }
        .btn-primary { background: var(--accent); color: #fff; }
        .btn-primary:hover { background: var(--accent-h); }
        .btn-ghost { background: transparent; color: var(--text-muted); border: 1px solid var(--border); flex: 0 0 auto; }
        .btn-ghost:hover { background: var(--surface-2); }
        .validation-msg { font-size: 12px; color: var(--danger); margin-top: 4px; }
    </style>
</head>
<body>

<aside class="sidebar">
    <div class="sidebar-brand">
        <span class="logo">Tria</span><span class="badge">Admin</span>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-section-title">Главное</div>
        <a href="/Admin" class="nav-item">
            <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
            Обзор
        </a>
        <a href="/Admin/AssignCourse" class="nav-item">
            <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            Назначить курс
        </a>
        <a href="/Admin/AssignTeacher" class="nav-item">
            <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Назначить учеников
        </a>
        <a href="/Admin/CreateUser" class="nav-item active">
            <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
            Добавить пользователя
        </a>
        <div class="nav-section-title">Аналитика</div>
        <a href="/Admin/Reviews" class="nav-item">
            <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Отзывы
        </a>
        <div class="nav-section-title">Инструменты</div>
        <a href="/Admin/SqlConsole" class="nav-item">
            <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
            SQL Консоль
        </a>
    </nav>
    <div class="sidebar-footer">
        <div class="user-chip">
            <div class="user-avatar">A</div>
            <div class="user-info">
                <div class="user-email">@User.Identity!.Name</div>
                <div class="user-role">Администратор</div>
            </div>
        </div>
        <form method="post" action="/Logout" style="margin-top:8px;padding:0 10px;">
            @Html.AntiForgeryToken()
            <button type="submit" style="background:none;border:none;color:var(--sidebar-muted);font-size:13px;cursor:pointer;padding:4px 0;">Выйти</button>
        </form>
    </div>
</aside>

<div class="main">
    <div class="topbar">
        <div class="breadcrumb">
            <a href="/Admin">Администрирование</a>
            <span class="sep">›</span>
            <span class="current">Новый пользователь</span>
        </div>
        <button type="button" class="theme-btn" id="theme-btn" onclick="toggleTheme()">🌙</button>
    </div>

    <div class="content">
        <div class="form-card">
            <h2>Создать пользователя</h2>
            <p>Новый пользователь сможет войти в систему сразу после создания.</p>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="error-msg">@Model.ErrorMessage</div>
            }

            <form method="post">
                @Html.AntiForgeryToken()

                <div class="field">
                    <label for="email">Email</label>
                    <input id="email" type="email" name="Input.Email" value="@Model.Input.Email"
                           placeholder="user@example.com" autocomplete="email" />
                    @if (!string.IsNullOrEmpty(ModelState["Input.Email"]?.Errors.FirstOrDefault()?.ErrorMessage))
                    {
                        <div class="validation-msg">@ModelState["Input.Email"]!.Errors[0].ErrorMessage</div>
                    }
                </div>

                <div class="field">
                    <label for="password">Пароль</label>
                    <input id="password" type="password" name="Input.Password" placeholder="Введите пароль" autocomplete="new-password" />
                    @if (!string.IsNullOrEmpty(ModelState["Input.Password"]?.Errors.FirstOrDefault()?.ErrorMessage))
                    {
                        <div class="validation-msg">@ModelState["Input.Password"]!.Errors[0].ErrorMessage</div>
                    }
                </div>

                <div class="field">
                    <label>Роль</label>
                    <div class="role-grid">
                        <div class="role-option">
                            <input type="radio" id="role-student" name="Input.Role" value="Student" checked />
                            <label class="role-label" for="role-student">
                                <div class="role-name">Student</div>
                                <div class="role-desc">Обычный обучающийся</div>
                            </label>
                        </div>
                        <div class="role-option">
                            <input type="radio" id="role-teacher" name="Input.Role" value="Teacher" />
                            <label class="role-label" for="role-teacher">
                                <div class="role-name">Teacher</div>
                                <div class="role-desc">Преподаватель</div>
                            </label>
                        </div>
                        <div class="role-option">
                            <input type="radio" id="role-expert" name="Input.Role" value="Expert" />
                            <label class="role-label" for="role-expert">
                                <div class="role-name">Expert</div>
                                <div class="role-desc">Эксперт</div>
                            </label>
                        </div>
                        <div class="role-option">
                            <input type="radio" id="role-admin" name="Input.Role" value="Admin" />
                            <label class="role-label" for="role-admin">
                                <div class="role-name">Admin</div>
                                <div class="role-desc">Администратор</div>
                            </label>
                        </div>
                    </div>
                </div>

                <div class="btn-row">
                    <a href="/Admin" class="btn btn-ghost" style="flex:0 0 auto;padding:10px 20px;">Отмена</a>
                    <button type="submit" class="btn btn-primary">Создать пользователя</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    var themeBtn = document.getElementById("theme-btn");
    themeBtn.textContent = localStorage.getItem("theme") === "dark" ? "☀️" : "🌙";
    function toggleTheme() {
        var isDark = document.documentElement.getAttribute("data-theme") === "dark";
        document.documentElement.setAttribute("data-theme", isDark ? "light" : "dark");
        localStorage.setItem("theme", isDark ? "light" : "dark");
        themeBtn.textContent = isDark ? "🌙" : "☀️";
    }
</script>
</body>
</html>
