@page "/Admin/UserDetail"
@model Tria.Pages.Admin.UserDetailModel
@{
    Layout = null;
    var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var userInitial = (Model.TargetUser?.Email ?? "?")[0].ToString().ToUpper();
}
<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script>(function(){ if(localStorage.getItem("theme")==="dark") document.documentElement.setAttribute("data-theme","dark"); })();</script>
    <title>@Model.TargetUser?.Email – Tria Admin</title>
    <style>
        :root { --bg:#f3f4f6; --surface:#ffffff; --surface-2:#f9fafb; --border:#d1d5db; --border-2:#e5e7eb; --text:#111827; --text-muted:#6b7280; --text-sub:#4b5563; --shadow:rgba(0,0,0,0.06); --accent:#2563eb; --accent-h:#1d4ed8; --success:#16a34a; --sidebar-bg:#1c1010; --sidebar-text:#f1e8e8; --sidebar-muted:#b89898; --sidebar-active:#dc2626; --sidebar-hover:rgba(255,255,255,0.06); }
        [data-theme="dark"] { --bg:#0f1117; --surface:#1a1d2e; --surface-2:#151826; --border:#2a2d3e; --border-2:#222536; --text:#f1f5f9; --text-muted:#94a3b8; --text-sub:#cbd5e1; --shadow:rgba(0,0,0,0.4); --sidebar-bg:#110808; }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background: var(--bg); color: var(--text); display: flex; min-height: 100vh; }
        a { color: var(--accent); text-decoration: none; }
        .sidebar { width: 240px; background: var(--sidebar-bg); color: var(--sidebar-text); display: flex; flex-direction: column; padding: 0; flex-shrink: 0; min-height: 100vh; position: sticky; top: 0; height: 100vh; overflow-y: auto; }
        .sidebar-brand { padding: 24px 20px 20px; border-bottom: 1px solid rgba(255,255,255,0.08); }
        .sidebar-brand .logo { font-size: 20px; font-weight: 800; color: #fff; }
        .sidebar-brand .badge { display: inline-block; margin-left: 8px; background: var(--sidebar-active); color: #fff; font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 99px; text-transform: uppercase; letter-spacing: 0.5px; vertical-align: middle; }
        .sidebar-nav { padding: 16px 12px; flex: 1; }
        .nav-section-title { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; color: var(--sidebar-muted); padding: 8px 8px 6px; margin-top: 8px; }
        .nav-item { display: flex; align-items: center; gap: 10px; padding: 9px 10px; border-radius: 8px; color: var(--sidebar-muted); font-size: 14px; font-weight: 500; cursor: pointer; transition: background 0.15s, color 0.15s; text-decoration: none; margin-bottom: 2px; }
        .nav-item:hover { background: var(--sidebar-hover); color: var(--sidebar-text); text-decoration: none; }
        .nav-item.active { background: rgba(220,38,38,0.20); color: #fca5a5; }
        .nav-item .icon { width: 18px; height: 18px; flex-shrink: 0; }
        .sidebar-footer { padding: 16px 12px; border-top: 1px solid rgba(255,255,255,0.08); }
        .user-chip { display: flex; align-items: center; gap: 10px; padding: 8px 10px; border-radius: 8px; }
        .user-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--sidebar-active); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; color: #fff; flex-shrink: 0; }
        .user-info { min-width: 0; }
        .user-email { font-size: 12px; color: var(--sidebar-text); font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .user-role { font-size: 11px; color: var(--sidebar-muted); }
        .main { flex: 1; display: flex; flex-direction: column; min-width: 0; }
        .topbar { background: var(--surface); border-bottom: 1px solid var(--border); padding: 0 32px; height: 60px; display: flex; align-items: center; justify-content: space-between; gap: 16px; position: sticky; top: 0; z-index: 10; }
        .breadcrumb { display: flex; align-items: center; gap: 6px; font-size: 14px; }
        .breadcrumb a { color: var(--text-muted); }
        .breadcrumb a:hover { color: var(--text); }
        .breadcrumb .sep { color: var(--text-muted); }
        .breadcrumb .current { font-weight: 600; color: var(--text); }
        .theme-btn { width: 34px; height: 34px; border: 1px solid var(--border); border-radius: 6px; background: var(--surface); cursor: pointer; font-size: 16px; display: flex; align-items: center; justify-content: center; }
        .content { padding: 28px 32px; flex: 1; }
        .two-col { display: grid; grid-template-columns: 320px 1fr; gap: 24px; align-items: start; }
        .card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
        .card-header { padding: 18px 20px 14px; border-bottom: 1px solid var(--border); }
        .card-header h3 { font-size: 14px; font-weight: 700; }
        .card-body { padding: 20px; }

        /* User profile card */
        .profile-header { display: flex; align-items: center; gap: 16px; margin-bottom: 20px; }
        .profile-avatar { width: 56px; height: 56px; border-radius: 50%; background: var(--accent); display: flex; align-items: center; justify-content: center; font-size: 22px; font-weight: 800; color: #fff; flex-shrink: 0; }
        .profile-name { font-size: 16px; font-weight: 700; word-break: break-all; }
        .profile-meta { font-size: 13px; color: var(--text-muted); margin-top: 2px; }
        .role-badge { display: inline-block; padding: 2px 8px; border-radius: 99px; font-size: 11px; font-weight: 600; }
        .role-student { background: rgba(37,99,235,0.12); color: var(--accent); }
        .role-teacher { background: rgba(16,185,129,0.12); color: #10b981; }
        .role-expert { background: rgba(245,158,11,0.12); color: #f59e0b; }
        .role-admin { background: rgba(239,68,68,0.12); color: #ef4444; }
        .role-default { background: var(--surface-2); color: var(--text-muted); }
        .stats-mini { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
        .stat-mini { background: var(--surface-2); border: 1px solid var(--border-2); border-radius: 10px; padding: 14px 16px; }
        .stat-mini-label { font-size: 11px; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
        .stat-mini-value { font-size: 24px; font-weight: 800; color: var(--text); }
        .stat-mini-value.accent { color: var(--accent); }

        /* Course assignment */
        .course-list { display: flex; flex-direction: column; gap: 10px; }
        .course-item { display: flex; align-items: center; gap: 14px; padding: 14px 16px; border: 1px solid var(--border-2); border-radius: 10px; background: var(--surface-2); transition: border-color 0.15s, background 0.15s; cursor: pointer; }
        .course-item:hover { border-color: var(--accent); background: rgba(37,99,235,0.04); }
        .course-item input[type=checkbox] { width: 18px; height: 18px; accent-color: var(--accent); cursor: pointer; flex-shrink: 0; }
        .course-item-body { flex: 1; min-width: 0; }
        .course-title { font-size: 14px; font-weight: 600; margin-bottom: 6px; }
        .progress-bar { height: 5px; background: var(--border); border-radius: 3px; overflow: hidden; }
        .progress-fill { height: 100%; border-radius: 3px; transition: width 0.3s; }
        .progress-text { font-size: 11px; color: var(--text-muted); margin-top: 4px; }
        .course-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; background: var(--border); }
        .save-bar { position: sticky; bottom: 0; background: var(--surface); border-top: 1px solid var(--border); padding: 14px 20px; display: flex; justify-content: flex-end; gap: 10px; }
        .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 18px; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; border: none; transition: background 0.15s; text-decoration: none; }
        .btn-primary { background: var(--accent); color: #fff; }
        .btn-primary:hover { background: var(--accent-h); }
        .btn-ghost { background: transparent; color: var(--text-muted); border: 1px solid var(--border); }
        .btn-ghost:hover { background: var(--surface-2); }
        .saved-msg { display: none; color: var(--success); font-size: 13px; font-weight: 600; align-items: center; gap: 4px; }
    </style>
</head>
<body>

<aside class="sidebar">
    <div class="sidebar-brand">
        <span class="logo">Tria</span><span class="badge">Admin</span>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-section-title">Главное</div>
        <a href="/Admin" class="nav-item active">
            <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
            Обзор
        </a>
        <a href="/Admin/AssignCourse" class="nav-item">
            <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            Назначить курс
        </a>
        <a href="/Admin/CreateUser" class="nav-item">
            <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
            Добавить пользователя
        </a>
    </nav>
    <div class="sidebar-footer">
        <div class="user-chip">
            <div class="user-avatar">A</div>
            <div class="user-info">
                <div class="user-email">@User.Identity!.Name</div>
                <div class="user-role">Администратор</div>
            </div>
        </div>
        <form method="post" action="/Logout" style="margin-top:8px;padding:0 10px;">
            @Html.AntiForgeryToken()
            <button type="submit" style="background:none;border:none;color:var(--sidebar-muted);font-size:13px;cursor:pointer;padding:4px 0;">Выйти</button>
        </form>
    </div>
</aside>

<div class="main">
    <div class="topbar">
        <div class="breadcrumb">
            <a href="/Admin">Администрирование</a>
            <span class="sep">›</span>
            <span class="current">@Model.TargetUser?.Email</span>
        </div>
        <button type="button" class="theme-btn" id="theme-btn" onclick="toggleTheme()">🌙</button>
    </div>

    <div class="content">
        <div class="two-col">

            <!-- Left: profile -->
            <div>
                <div class="card" style="margin-bottom:20px;">
                    <div class="card-header"><h3>Профиль</h3></div>
                    <div class="card-body">
                        <div class="profile-header">
                            <div class="profile-avatar">@userInitial</div>
                            <div>
                                <div class="profile-name">@Model.TargetUser?.Email</div>
                                <div class="profile-meta">
                                    @{
                                        var roleCls = Model.UserRole.ToLower() switch
                                        {
                                            "admin"   => "role-admin",
                                            "student" => "role-student",
                                            "teacher" => "role-teacher",
                                            "expert"  => "role-expert",
                                            _         => "role-default"
                                        };
                                    }
                                    <span class="role-badge @roleCls">@Model.UserRole</span>
                                </div>
                            </div>
                        </div>
                        <div class="stats-mini">
                            <div class="stat-mini">
                                <div class="stat-mini-label">Курсов</div>
                                <div class="stat-mini-value accent">@Model.Courses.Count(c => c.IsAssigned)</div>
                            </div>
                            <div class="stat-mini">
                                <div class="stat-mini-label">Уроков</div>
                                <div class="stat-mini-value">@Model.CompletedLessons</div>
                            </div>
                            <div class="stat-mini" style="grid-column:span 2;">
                                <div class="stat-mini-label">XP заработано</div>
                                <div class="stat-mini-value accent">⚡ @Model.TotalXp</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: course assignment -->
            <div>
                <form method="post" asp-page-handler="SaveCourses">
                    <input type="hidden" name="userId" value="@Model.TargetUser?.Id" />
                    @Html.AntiForgeryToken()

                    <div class="card">
                        <div class="card-header">
                            <h3>Назначенные курсы</h3>
                        </div>
                        <div class="card-body">
                            @if (!Model.Courses.Any())
                            {
                                <p style="color:var(--text-muted);font-size:14px;">Курсы не найдены в системе.</p>
                            }
                            else
                            {
                                <div class="course-list">
                                    @foreach (var course in Model.Courses)
                                    {
                                        var dotColor = course.Color ?? "var(--border)";
                                        var fillColor = course.IsAssigned ? (course.Color ?? "var(--accent)") : "var(--border)";
                                        <label class="course-item" for="course-@course.CourseId">
                                            <input type="checkbox"
                                                   id="course-@course.CourseId"
                                                   name="assignedCourseIds"
                                                   value="@course.CourseId"
                                                   @(course.IsAssigned ? "checked" : "") />
                                            <div class="course-dot" style="background:@dotColor;"></div>
                                            <div class="course-item-body">
                                                <div class="course-title">@course.Title</div>
                                                <div class="progress-bar">
                                                    <div class="progress-fill" style="width:@course.ProgressPercent%;background:@fillColor;"></div>
                                                </div>
                                                <div class="progress-text">Прогресс: @course.ProgressPercent%</div>
                                            </div>
                                        </label>
                                    }
                                </div>
                            }
                        </div>
                        <div class="save-bar">
                            <a href="/Admin" class="btn btn-ghost">Отмена</a>
                            <button type="submit" class="btn btn-primary">Сохранить изменения</button>
                        </div>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

<script>
    var themeBtn = document.getElementById("theme-btn");
    themeBtn.textContent = localStorage.getItem("theme") === "dark" ? "☀️" : "🌙";
    function toggleTheme() {
        var isDark = document.documentElement.getAttribute("data-theme") === "dark";
        document.documentElement.setAttribute("data-theme", isDark ? "light" : "dark");
        localStorage.setItem("theme", isDark ? "light" : "dark");
        themeBtn.textContent = isDark ? "🌙" : "☀️";
    }
</script>
</body>
</html>
