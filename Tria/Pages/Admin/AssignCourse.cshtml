@page "/Admin/AssignCourse"
@model Tria.Pages.Admin.AssignCourseModel
@{
    Layout = null;
    var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var usersJson = System.Text.Json.JsonSerializer.Serialize(Model.Users.Select(u => new { u.Id, u.Email, u.Role }));
    var coursesJson = System.Text.Json.JsonSerializer.Serialize(Model.Courses.Select(c => new { c.Id, c.Title, c.Color }));
    var assignmentsJson = System.Text.Json.JsonSerializer.Serialize(Model.UserAssignments);
}
<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script>(function(){ if(localStorage.getItem("theme")==="dark") document.documentElement.setAttribute("data-theme","dark"); })();</script>
    <title>Назначить курс – Tria Admin</title>
    <style>
        :root { --bg:#f3f4f6; --surface:#ffffff; --surface-2:#f9fafb; --border:#d1d5db; --border-2:#e5e7eb; --text:#111827; --text-muted:#6b7280; --accent:#2563eb; --accent-h:#1d4ed8; --success:#16a34a; --success-bg:rgba(22,163,74,0.08); --warn:#d97706; --warn-bg:rgba(217,119,6,0.10); --sidebar-bg:#1c1010; --sidebar-text:#f1e8e8; --sidebar-muted:#b89898; --sidebar-active:#dc2626; --sidebar-hover:rgba(255,255,255,0.06); }
        [data-theme="dark"] { --bg:#0f1117; --surface:#1a1d2e; --surface-2:#151826; --border:#2a2d3e; --border-2:#222536; --text:#f1f5f9; --text-muted:#94a3b8; --sidebar-bg:#110808; }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background: var(--bg); color: var(--text); display: flex; min-height: 100vh; }
        a { color: var(--accent); text-decoration: none; }

        /* Sidebar */
        .sidebar { width: 240px; background: var(--sidebar-bg); color: var(--sidebar-text); display: flex; flex-direction: column; flex-shrink: 0; min-height: 100vh; position: sticky; top: 0; height: 100vh; overflow-y: auto; }
        .sidebar-brand { padding: 24px 20px 20px; border-bottom: 1px solid rgba(255,255,255,0.08); }
        .sidebar-brand .logo { font-size: 20px; font-weight: 800; color: #fff; }
        .sidebar-brand .badge { display: inline-block; margin-left: 8px; background: var(--sidebar-active); color: #fff; font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 99px; text-transform: uppercase; letter-spacing: 0.5px; vertical-align: middle; }
        .sidebar-nav { padding: 16px 12px; flex: 1; }
        .nav-section-title { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; color: var(--sidebar-muted); padding: 8px 8px 6px; margin-top: 8px; }
        .nav-item { display: flex; align-items: center; gap: 10px; padding: 9px 10px; border-radius: 8px; color: var(--sidebar-muted); font-size: 14px; font-weight: 500; transition: background 0.15s, color 0.15s; text-decoration: none; margin-bottom: 2px; }
        .nav-item:hover { background: var(--sidebar-hover); color: var(--sidebar-text); text-decoration: none; }
        .nav-item.active { background: rgba(220,38,38,0.20); color: #fca5a5; }
        .nav-item .icon { width: 18px; height: 18px; flex-shrink: 0; }
        .sidebar-footer { padding: 16px 12px; border-top: 1px solid rgba(255,255,255,0.08); }
        .user-chip { display: flex; align-items: center; gap: 10px; padding: 8px 10px; }
        .user-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--sidebar-active); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; color: #fff; flex-shrink: 0; }
        .user-info { min-width: 0; }
        .user-email { font-size: 12px; color: var(--sidebar-text); font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .user-role-lbl { font-size: 11px; color: var(--sidebar-muted); }

        /* Main */
        .main { flex: 1; display: flex; flex-direction: column; min-width: 0; }
        .topbar { background: var(--surface); border-bottom: 1px solid var(--border); padding: 0 32px; height: 60px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 10; }
        .breadcrumb { display: flex; align-items: center; gap: 6px; font-size: 14px; }
        .breadcrumb a { color: var(--text-muted); }
        .breadcrumb a:hover { color: var(--text); }
        .breadcrumb .sep { color: var(--text-muted); }
        .breadcrumb .current { font-weight: 600; color: var(--text); }
        .theme-btn { width: 34px; height: 34px; border: 1px solid var(--border); border-radius: 6px; background: var(--surface); cursor: pointer; font-size: 16px; display: flex; align-items: center; justify-content: center; }

        .content { padding: 32px; display: flex; justify-content: center; align-items: flex-start; }
        .wizard { width: 100%; max-width: 560px; display: flex; flex-direction: column; gap: 0; }

        /* Steps */
        .step { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; margin-bottom: 16px; transition: opacity 0.2s; }
        .step.locked { opacity: 0.45; pointer-events: none; }
        .step-header { padding: 18px 22px 16px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 14px; }
        .step-num { width: 28px; height: 28px; border-radius: 50%; background: var(--accent); color: #fff; font-size: 13px; font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .step.locked .step-num { background: var(--border); }
        .step-title { font-size: 15px; font-weight: 700; }
        .step-subtitle { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
        .step-body { padding: 18px 22px 20px; }

        /* Search */
        .search-wrap { position: relative; margin-bottom: 12px; }
        .search-wrap input { width: 100%; padding: 11px 14px 11px 40px; border: 1px solid var(--border); border-radius: 10px; background: var(--surface-2); color: var(--text); font-size: 14px; outline: none; transition: border-color 0.15s, box-shadow 0.15s; }
        .search-wrap input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(37,99,235,0.1); background: var(--surface); }
        .search-icon { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 15px; pointer-events: none; }
        .search-hint { font-size: 12px; color: var(--text-muted); margin-bottom: 10px; }

        /* User list */
        .result-list { max-height: 240px; overflow-y: auto; border: 1px solid var(--border); border-radius: 10px; background: var(--surface-2); }
        .result-item { display: flex; align-items: center; gap: 12px; padding: 11px 14px; cursor: pointer; transition: background 0.12s; border-bottom: 1px solid var(--border-2); }
        .result-item:last-child { border-bottom: none; }
        .result-item:hover { background: rgba(37,99,235,0.06); }
        .result-item.hidden { display: none; }
        .result-dot { width: 9px; height: 9px; border-radius: 50%; background: var(--border); flex-shrink: 0; }
        .result-main { flex: 1; min-width: 0; }
        .result-email { font-size: 13px; font-weight: 600; color: var(--text); }
        .result-role { font-size: 11px; color: var(--text-muted); margin-top: 1px; }

        /* Selected chip */
        .selected-chip { display: inline-flex; align-items: center; gap: 8px; background: rgba(37,99,235,0.1); border: 1px solid rgba(37,99,235,0.25); color: var(--accent); border-radius: 8px; padding: 7px 12px; font-size: 13px; font-weight: 600; margin-bottom: 14px; }
        .chip-x { cursor: pointer; opacity: 0.6; font-size: 16px; line-height: 1; display: flex; }
        .chip-x:hover { opacity: 1; }

        /* Course items */
        .course-item { display: flex; align-items: center; gap: 12px; padding: 12px 14px; border: 1px solid var(--border-2); border-radius: 10px; background: var(--surface-2); cursor: pointer; transition: border-color 0.15s, background 0.15s; margin-bottom: 8px; }
        .course-item:hover { border-color: var(--accent); background: rgba(37,99,235,0.04); }
        .course-item.hidden { display: none; }
        .course-item.selected { border-color: var(--accent); background: rgba(37,99,235,0.08); }
        /* Already-assigned state */
        .course-item.already { border-color: rgba(22,163,74,0.4); background: rgba(22,163,74,0.05); }
        .course-item.already:hover { border-color: rgba(22,163,74,0.6); background: rgba(22,163,74,0.09); }
        .course-item.already.selected { border-color: var(--accent); background: rgba(37,99,235,0.08); }
        .course-color-dot { width: 12px; height: 12px; border-radius: 50%; background: var(--border); flex-shrink: 0; }
        .course-name { font-size: 14px; font-weight: 600; flex: 1; }
        .assigned-badge { display: none; align-items: center; gap: 4px; font-size: 11px; font-weight: 700; color: #16a34a; background: rgba(22,163,74,0.12); border: 1px solid rgba(22,163,74,0.25); border-radius: 99px; padding: 2px 8px; white-space: nowrap; flex-shrink: 0; }
        .course-item.already .assigned-badge { display: flex; }
        .course-check { width: 20px; height: 20px; border-radius: 50%; border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: background 0.15s, border-color 0.15s; }
        .course-item.selected .course-check { background: var(--accent); border-color: var(--accent); }
        .course-check-inner { width: 10px; height: 10px; border-radius: 50%; background: #fff; display: none; }
        .course-item.selected .course-check-inner { display: block; }

        /* Assign bar */
        .assign-bar { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 18px 22px; display: flex; align-items: center; justify-content: space-between; gap: 16px; }
        .assign-summary { font-size: 13px; color: var(--text-muted); }
        .assign-summary strong { color: var(--text); }
        .btn { display: inline-flex; align-items: center; gap: 6px; padding: 10px 22px; border-radius: 9px; font-size: 14px; font-weight: 700; cursor: pointer; border: none; transition: background 0.15s, opacity 0.15s; }
        .btn-primary { background: var(--accent); color: #fff; }
        .btn-primary:hover:not(:disabled) { background: var(--accent-h); }
        .btn-primary:disabled { opacity: 0.4; cursor: not-allowed; }

        /* Messages */
        .success-msg { display: flex; align-items: center; gap: 10px; background: var(--success-bg); border: 1px solid rgba(22,163,74,0.25); border-radius: 10px; padding: 14px 18px; font-size: 14px; color: var(--success); font-weight: 600; margin-bottom: 16px; }
        .warn-msg { display: flex; align-items: center; gap: 10px; background: var(--warn-bg); border: 1px solid rgba(217,119,6,0.25); border-radius: 10px; padding: 14px 18px; font-size: 14px; color: var(--warn); font-weight: 600; margin-bottom: 16px; }
        .msg-icon { font-size: 18px; }
        .already-warn { display: none; align-items: center; gap: 6px; font-size: 12px; color: var(--warn); margin-top: 8px; }
    </style>
</head>
<body>

<!-- Sidebar -->
<aside class="sidebar">
    <div class="sidebar-brand">
        <span class="logo">Tria</span><span class="badge">Admin</span>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-section-title">Главное</div>
        <a href="/Admin" class="nav-item">
            <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
            Обзор
        </a>
        <a href="/Admin/AssignCourse" class="nav-item active">
            <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            Назначить курс
        </a>
        <a href="/Admin/AssignTeacher" class="nav-item">
            <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Назначить учеников
        </a>
        <a href="/Admin/CreateUser" class="nav-item">
            <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
            Добавить пользователя
        </a>
        <div class="nav-section-title">Инструменты</div>
        <a href="/Admin/SqlConsole" class="nav-item">
            <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
            SQL Консоль
        </a>
    </nav>
    <div class="sidebar-footer">
        <div class="user-chip">
            <div class="user-avatar">A</div>
            <div class="user-info">
                <div class="user-email">@User.Identity!.Name</div>
                <div class="user-role-lbl">Администратор</div>
            </div>
        </div>
        <form method="post" action="/Logout" style="margin-top:8px;padding:0 10px;">
            @Html.AntiForgeryToken()
            <button type="submit" style="background:none;border:none;color:var(--sidebar-muted);font-size:13px;cursor:pointer;padding:4px 0;">Выйти</button>
        </form>
    </div>
</aside>

<!-- Main -->
<div class="main">
    <div class="topbar">
        <div class="breadcrumb">
            <a href="/Admin">Администрирование</a>
            <span class="sep">›</span>
            <span class="current">Назначить курс</span>
        </div>
        <button type="button" class="theme-btn" id="theme-btn" onclick="toggleTheme()">🌙</button>
    </div>

    <div class="content">
        <div class="wizard">

            @if (!string.IsNullOrEmpty(Model.SuccessMessage))
            {
                var isAlready = Model.SuccessMessage.Contains("уже назначен");
                <div class="@(isAlready ? "warn-msg" : "success-msg")">
                    <span class="msg-icon">@(isAlready ? "⚠️" : "✓")</span>
                    @Model.SuccessMessage
                </div>
            }

            <!-- Step 1: pick user -->
            <div class="step" id="step-user">
                <div class="step-header">
                    <div class="step-num">1</div>
                    <div>
                        <div class="step-title">Выберите пользователя</div>
                        <div class="step-subtitle">Только студенты, преподаватели и эксперты</div>
                    </div>
                </div>
                <div class="step-body">
                    <div id="user-selected-chip" style="display:none;"></div>
                    <div id="user-search-area">
                        <div class="search-wrap">
                            <span class="search-icon">🔍</span>
                            <input type="text" id="user-search" placeholder="Введите email пользователя..." autocomplete="off" oninput="filterUsers()" />
                        </div>
                        <div class="search-hint">Начните вводить email для поиска</div>
                        <div class="result-list" id="user-list">
                            @foreach (var u in Model.Users)
                            {
                                <div class="result-item" data-id="@u.Id" data-email="@u.Email.ToLower()" data-label="@u.Email" data-role="@u.Role" onclick="selectUser(this)">
                                    <div class="result-dot"></div>
                                    <div class="result-main">
                                        <div class="result-email">@u.Email</div>
                                        <div class="result-role">@u.Role</div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Step 2: pick course -->
            <div class="step locked" id="step-course">
                <div class="step-header">
                    <div class="step-num">2</div>
                    <div>
                        <div class="step-title">Выберите курс</div>
                        <div class="step-subtitle">Курсы уже назначенные пользователю отмечены зелёным</div>
                    </div>
                </div>
                <div class="step-body">
                    <div class="search-wrap">
                        <span class="search-icon">🔍</span>
                        <input type="text" id="course-search" placeholder="Введите название курса..." autocomplete="off" oninput="filterCourses()" />
                    </div>
                    <div class="search-hint">Начните вводить для поиска</div>
                    <div id="course-list">
                        @foreach (var c in Model.Courses)
                        {
                            <div class="course-item" data-id="@c.Id" data-title="@c.Title.ToLower()" data-label="@c.Title" data-color="@(c.Color ?? "#94a3b8")" onclick="selectCourse(this)">
                                <div class="course-color-dot" style="background:@(c.Color ?? "var(--border)")"></div>
                                <span class="course-name">@c.Title</span>
                                <div class="assigned-badge">
                                    <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                                    Уже назначен
                                </div>
                                <div class="course-check"><div class="course-check-inner"></div></div>
                            </div>
                        }
                    </div>
                    <div class="already-warn" id="already-warn">
                        ⚠️ Этот курс уже назначен выбранному пользователю
                    </div>
                </div>
            </div>

            <!-- Assign bar -->
            <form method="post" id="assign-form">
                @Html.AntiForgeryToken()
                <input type="hidden" id="input-userId" name="userId" value="" />
                <input type="hidden" id="input-courseId" name="courseId" value="" />
                <div class="assign-bar">
                    <div class="assign-summary" id="assign-summary">Выберите пользователя и курс</div>
                    <button type="submit" class="btn btn-primary" id="assign-btn" disabled>Назначить</button>
                </div>
            </form>

        </div>
    </div>
</div>

<script>
    var assignments = @Html.Raw(assignmentsJson);
    var selectedUser = null;
    var selectedCourse = null;

    var themeBtn = document.getElementById("theme-btn");
    themeBtn.textContent = localStorage.getItem("theme") === "dark" ? "☀️" : "🌙";
    function toggleTheme() {
        var isDark = document.documentElement.getAttribute("data-theme") === "dark";
        document.documentElement.setAttribute("data-theme", isDark ? "light" : "dark");
        localStorage.setItem("theme", isDark ? "light" : "dark");
        themeBtn.textContent = isDark ? "🌙" : "☀️";
    }

    function filterUsers() {
        var q = document.getElementById("user-search").value.toLowerCase().trim();
        document.querySelectorAll("#user-list .result-item").forEach(function(el) {
            el.classList.toggle("hidden", q !== "" && !el.dataset.email.includes(q));
        });
    }

    function selectUser(el) {
        selectedUser = { id: el.dataset.id, email: el.dataset.label };
        document.getElementById("input-userId").value = selectedUser.id;

        var chip = document.getElementById("user-selected-chip");
        chip.innerHTML = '<div class="selected-chip">' +
            '<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>' +
            selectedUser.email +
            '<span class="chip-x" onclick="clearUser()">✕</span></div>';
        chip.style.display = "block";
        document.getElementById("user-search-area").style.display = "none";
        document.getElementById("step-course").classList.remove("locked");

        // Mark already-assigned courses for this user
        var userAssigned = assignments[selectedUser.id] || [];
        document.querySelectorAll("#course-list .course-item").forEach(function(item) {
            var courseId = parseInt(item.dataset.id);
            if (userAssigned.indexOf(courseId) !== -1) {
                item.classList.add("already");
            } else {
                item.classList.remove("already");
            }
        });

        // Reset course selection
        clearCourseSelection();
        updateSummary();
    }

    function clearUser() {
        selectedUser = null;
        document.getElementById("input-userId").value = "";
        document.getElementById("user-selected-chip").style.display = "none";
        document.getElementById("user-search-area").style.display = "block";
        document.getElementById("user-search").value = "";
        filterUsers();
        document.getElementById("step-course").classList.add("locked");
        document.querySelectorAll("#course-list .course-item").forEach(function(item) {
            item.classList.remove("already");
        });
        clearCourseSelection();
        updateSummary();
    }

    function filterCourses() {
        var q = document.getElementById("course-search").value.toLowerCase().trim();
        document.querySelectorAll("#course-list .course-item").forEach(function(el) {
            el.classList.toggle("hidden", q !== "" && !el.dataset.title.includes(q));
        });
    }

    function selectCourse(el) {
        clearCourseSelection();
        el.classList.add("selected");
        selectedCourse = { id: el.dataset.id, title: el.dataset.label };
        document.getElementById("input-courseId").value = selectedCourse.id;

        // Show warning if already assigned
        var warn = document.getElementById("already-warn");
        warn.style.display = el.classList.contains("already") ? "flex" : "none";

        updateSummary();
    }

    function clearCourseSelection() {
        selectedCourse = null;
        document.getElementById("input-courseId").value = "";
        document.getElementById("already-warn").style.display = "none";
        document.querySelectorAll("#course-list .course-item").forEach(function(item) {
            item.classList.remove("selected");
        });
    }

    function updateSummary() {
        var summary = document.getElementById("assign-summary");
        var btn = document.getElementById("assign-btn");
        if (selectedUser && selectedCourse) {
            summary.innerHTML = 'Назначить <strong>' + selectedCourse.title + '</strong> → <strong>' + selectedUser.email + '</strong>';
            btn.disabled = false;
        } else if (selectedUser) {
            summary.innerHTML = 'Пользователь: <strong>' + selectedUser.email + '</strong> — выберите курс';
            btn.disabled = true;
        } else {
            summary.textContent = "Выберите пользователя и курс";
            btn.disabled = true;
        }
    }
</script>
</body>
</html>
