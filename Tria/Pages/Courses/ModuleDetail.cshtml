@page "/Module/{moduleId:int}"
@model Tria.Pages.Courses.ModuleDetailModel
@using Tria.Services
@using Tria.Models
@inject IUiLocalizer T
@{
    ViewData["Title"] = Model.Module?.Title ?? "Модуль";
    Layout = null;
    var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    string DiffLabel(DifficultyLevel d) => d switch { DifficultyLevel.Easy => "Лёгкий", DifficultyLevel.Medium => "Средний", DifficultyLevel.Hard => "Сложный", _ => "" };
    string DiffClass(DifficultyLevel d) => d switch { DifficultyLevel.Easy => "easy", DifficultyLevel.Medium => "medium", DifficultyLevel.Hard => "hard", _ => "easy" };
    string TestStatusLabel(TestStatus s) => s switch { TestStatus.Passed => "Сдан", TestStatus.Failed => "Не сдан", TestStatus.Checking => "Проверяется", _ => "" };
}
<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script>(function(){ if(localStorage.getItem("theme")==="dark") document.documentElement.setAttribute("data-theme","dark"); })();</script>
    <title>@ViewData["Title"] – Tria</title>
    <style>
        :root { --bg:#f3f4f6; --surface:#ffffff; --surface-2:#f9fafb; --border:#d1d5db; --border-2:#e5e7eb; --text:#111827; --text-muted:#6b7280; --text-sub:#4b5563; --progress-bg:#e5e7eb; --shadow:rgba(0,0,0,0.06); --accent:#2563eb; --accent-h:#1d4ed8; }
        [data-theme="dark"] { --bg:#0f1117; --surface:#1a1d2e; --surface-2:#151826; --border:#2a2d3e; --border-2:#222536; --text:#f1f5f9; --text-muted:#94a3b8; --text-sub:#cbd5e1; --progress-bg:#2a2d3e; --shadow:rgba(0,0,0,0.4); }
        * { box-sizing:border-box; margin:0; padding:0; }
        body { font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:var(--bg); color:var(--text); transition:background-color 0.3s,color 0.3s; }
        a { color:var(--accent); text-decoration:none; }
        a:hover { text-decoration:underline; }
        .page { min-height:100vh; padding:24px; }
        .shell { max-width:960px; margin:0 auto; }
        .top-bar { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; gap:12px; flex-wrap:wrap; }
        .breadcrumbs { display:flex; gap:8px; align-items:center; font-size:14px; color:var(--text-muted); flex-wrap:wrap; }
        .breadcrumbs a { color:var(--text-muted); }
        .breadcrumbs a:hover { color:var(--text); }
        .breadcrumbs span.cur { color:var(--text); font-weight:500; }
        .theme-btn { width:34px; height:34px; border:1px solid var(--border); border-radius:6px; background:var(--surface); cursor:pointer; font-size:16px; display:flex; align-items:center; justify-content:center; transition:border-color 0.2s,background-color 0.3s; }
        .theme-btn:hover { border-color:var(--text-muted); }
        .page-header { margin-bottom:24px; }
        .page-header h1 { font-size:22px; font-weight:700; margin-bottom:4px; }
        .lessons-list { display:flex; flex-direction:column; gap:12px; }
        .lesson-card { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:18px 20px; transition:box-shadow 0.2s,border-color 0.2s,background-color 0.3s; display:block; color:inherit; text-decoration:none; }
        .lesson-card:hover { box-shadow:0 4px 20px var(--shadow); border-color:var(--accent); text-decoration:none; }
        .lesson-top { display:flex; justify-content:space-between; align-items:flex-start; gap:12px; margin-bottom:10px; }
        .lesson-title { font-size:16px; font-weight:600; }
        .lesson-status-icon { font-size:20px; flex-shrink:0; }
        .badge { display:inline-block; padding:2px 8px; border-radius:99px; font-size:12px; font-weight:500; }
        .badge-easy   { background:#d1fae5; color:#065f46; }
        .badge-medium { background:#fef3c7; color:#92400e; }
        .badge-hard   { background:#fee2e2; color:#991b1b; }
        [data-theme="dark"] .badge-easy   { background:#064e3b; color:#6ee7b7; }
        [data-theme="dark"] .badge-medium { background:#78350f; color:#fde68a; }
        [data-theme="dark"] .badge-hard   { background:#7f1d1d; color:#fca5a5; }
        .lesson-meta { display:flex; gap:14px; align-items:center; flex-wrap:wrap; font-size:13px; color:var(--text-muted); }
        .meta-sep { color:var(--border); }
        .xp-badge { font-size:12px; font-weight:600; color:var(--accent); background:var(--surface-2); border:1px solid var(--border-2); padding:2px 8px; border-radius:99px; }
        .game-btn { display:inline-block; margin-top:20px; padding:10px 20px; background:var(--accent); color:#fff; border-radius:8px; font-size:14px; font-weight:600; text-decoration:none; transition:background 0.2s; }
        .game-btn:hover { background:var(--accent-h); text-decoration:none; color:#fff; }
        .empty { text-align:center; color:var(--text-muted); padding:60px; font-size:14px; }
    </style>
</head>
<body>
<div class="page">
    <div class="shell">

        <div class="top-bar">
            <div class="breadcrumbs">
                <a href="/Dashboard">Дашборд</a>
                <span>/</span>
                @if (Model.Course != null)
                {
                    <a href="/Course/@Model.Course.Id">@Model.Course.Title</a>
                    <span>/</span>
                }
                <span class="cur">@(Model.Module?.Title ?? "Модуль")</span>
            </div>
            <button type="button" class="theme-btn" id="theme-btn" onclick="toggleTheme()">🌙</button>
        </div>

        @if (Model.Module == null)
        {
            <div class="empty">Модуль не найден.</div>
        }
        else
        {
            <div class="page-header">
                <h1>@Model.Module.Title</h1>
                @if (!string.IsNullOrEmpty(Model.Module.Description))
                {
                    <p style="font-size:14px;color:var(--text-muted);margin-top:4px;">@Model.Module.Description</p>
                }
            </div>

            @if (!Model.Module.Lessons.Any())
            {
                <div class="empty">Уроков пока нет.</div>
            }
            else
            {
                <div class="lessons-list">
                    @foreach (var lesson in Model.Module.Lessons)
                    {
                        var prog    = Model.LessonProgress.GetValueOrDefault(lesson.Id);
                        var attempt = Model.LatestAttempts.GetValueOrDefault(lesson.Id);
                        bool matDone  = prog?.MaterialsCompleted == true;
                        bool testDone = prog?.TestPassed == true;
                        string statusIcon = (matDone && testDone) ? "✅" : matDone ? "📖" : "○";
                        string testLabel  = attempt != null ? TestStatusLabel(attempt.Status) : "Не начат";
                        string testPct    = attempt != null ? $"{attempt.ScorePercent}%" : "";
                        string testIcon   = attempt == null ? "○" : attempt.Status switch
                        {
                            TestStatus.Passed   => "✅",
                            TestStatus.Failed   => "❌",
                            TestStatus.Checking => "⏳",
                            _                   => "○"
                        };

                        <a href="/Lesson/@lesson.Id" class="lesson-card">
                            <div class="lesson-top">
                                <div class="lesson-title">@lesson.Title</div>
                                <div class="lesson-status-icon">@statusIcon</div>
                            </div>
                            <div class="lesson-meta">
                                <span class="badge badge-@DiffClass(lesson.Difficulty)">@DiffLabel(lesson.Difficulty)</span>
                                <span class="meta-sep">|</span>
                                <span>📚 Материалы: @(matDone ? "✓" : "—")</span>
                                @if (lesson.Test != null)
                                {
                                    <span class="meta-sep">|</span>
                                    <span>📝 Тест: @testIcon @testLabel @(testPct != "" ? $"({testPct})" : "")</span>
                                }
                                <span class="meta-sep">|</span>
                                <span class="xp-badge">⚡ @lesson.XpReward XP</span>
                            </div>
                        </a>
                    }
                </div>
            }

            @if (Model.Module.HasGame)
            {
                <div style="margin-top:24px;">
                    <a href="/Module/@Model.Module.Id/Game" class="game-btn">🎮 Открыть игру</a>
                </div>
            }
        }

    </div>
</div>
<script>
    var btn = document.getElementById("theme-btn");
    btn.textContent = localStorage.getItem("theme") === "dark" ? "☀️" : "🌙";
    function toggleTheme() {
        var d = document.documentElement.getAttribute("data-theme") === "dark";
        document.documentElement.setAttribute("data-theme", d ? "light" : "dark");
        localStorage.setItem("theme", d ? "light" : "dark");
        btn.textContent = d ? "🌙" : "☀️";
    }
</script>
</body>
</html>
