@page "/Dashboard"
@model Tria.Pages.DashboardModel
@using Tria.Services
@using Tria.Models
@inject IUiLocalizer T
@{
    ViewData["Title"] = "Дашборд";
    Layout = null;
    var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}
<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script>(function(){ if(localStorage.getItem("theme")==="dark") document.documentElement.setAttribute("data-theme","dark"); })();</script>
    <title>@ViewData["Title"] – Tria</title>
    <style>
        :root { --bg:#f3f4f6; --surface:#ffffff; --surface-2:#f9fafb; --border:#d1d5db; --border-2:#e5e7eb; --text:#111827; --text-muted:#6b7280; --text-sub:#4b5563; --progress-bg:#e5e7eb; --shadow:rgba(0,0,0,0.06); --accent:#2563eb; --accent-h:#1d4ed8; }
        [data-theme="dark"] { --bg:#0f1117; --surface:#1a1d2e; --surface-2:#151826; --border:#2a2d3e; --border-2:#222536; --text:#f1f5f9; --text-muted:#94a3b8; --text-sub:#cbd5e1; --text-light:#e2e8f0; --progress-bg:#2a2d3e; --shadow:rgba(0,0,0,0.4); }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background: var(--bg); color: var(--text); transition: background-color 0.3s, color 0.3s; }
        a { color: var(--accent); text-decoration: none; }
        a:hover { text-decoration: underline; }
        .page { min-height: 100vh; padding: 24px; }
        .shell { max-width: 960px; margin: 0 auto; }
        .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; gap: 12px; flex-wrap: wrap; }
        .brand { font-size: 18px; font-weight: 700; color: var(--text); }
        .nav-links { display: flex; gap: 16px; align-items: center; font-size: 14px; }
        .nav-links a { color: var(--text-muted); }
        .nav-links a:hover { color: var(--text); }
        .right-bar { display: flex; align-items: center; gap: 12px; }
        .theme-btn { width: 34px; height: 34px; border: 1px solid var(--border); border-radius: 6px; background: var(--surface); cursor: pointer; font-size: 16px; display: flex; align-items: center; justify-content: center; transition: border-color 0.2s, background-color 0.3s; }
        .theme-btn:hover { border-color: var(--text-muted); }
        .xp-chip { font-size: 13px; background: var(--surface); border: 1px solid var(--border); border-radius: 99px; padding: 4px 12px; font-weight: 600; color: var(--accent); }
        .logout-btn { font-size: 13px; color: var(--text-muted); background: none; border: none; cursor: pointer; padding: 0; }
        .logout-btn:hover { color: var(--text); }
        .welcome { margin-bottom: 28px; }
        .welcome h1 { font-size: 24px; font-weight: 700; margin-bottom: 4px; }
        .welcome p  { font-size: 14px; color: var(--text-muted); }
        .courses-grid { display: grid; gap: 16px; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); }
        .course-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 22px; cursor: pointer; transition: box-shadow 0.2s, border-color 0.2s, background-color 0.3s; }
        .course-card:hover { box-shadow: 0 4px 20px var(--shadow); border-color: var(--accent); }
        .course-card h2 { font-size: 17px; font-weight: 600; margin-bottom: 6px; }
        .course-desc { font-size: 13px; color: var(--text-muted); margin-bottom: 14px; line-height: 1.5; }
        .progress-bar { height: 6px; background: var(--progress-bg); border-radius: 3px; overflow: hidden; }
        .progress-fill { height: 100%; background: var(--accent); border-radius: 3px; transition: width 0.4s; }
        .progress-label { display: flex; justify-content: space-between; font-size: 12px; color: var(--text-muted); margin-top: 5px; }
        .module-count { font-size: 12px; color: var(--text-muted); margin-bottom: 12px; }
        .empty { text-align: center; color: var(--text-muted); padding: 60px; font-size: 14px; }
    </style>
</head>
<body>
<div class="page">
    <div class="shell">

        <div class="top-bar">
            <div style="display:flex;align-items:center;gap:20px;">
                <span class="brand">Tria</span>
                <nav class="nav-links">
                    <a href="/Dashboard">Курсы</a>
                    <a href="/Progress">Прогресс</a>
                    <a href="/Achievements">Достижения</a>
                </nav>
            </div>
            <div class="right-bar">
                <span class="xp-chip">⚡ @Model.TotalXp XP</span>
                <form method="post" action="/Logout" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="logout-btn">Выйти</button>
                </form>
                <button type="button" class="theme-btn" id="theme-btn" onclick="toggleTheme()">🌙</button>
            </div>
        </div>

        <div class="welcome">
            <h1>Добро пожаловать, @User.Identity!.Name!</h1>
            <p>Продолжайте обучение с того места, где остановились.</p>
        </div>

        @if (!Model.Courses.Any())
        {
            <div class="empty">Курсы не найдены.</div>
        }
        else
        {
            <div class="courses-grid">
                @foreach (var course in Model.Courses)
                {
                    var pct = Model.CourseProgress.GetValueOrDefault(course.Id, 0);
                    var lessonCount = course.Modules.Sum(m => m.Lessons.Count);
                    <a href="/Course/@course.Id" style="display:block;text-decoration:none;color:inherit;">
                        <div class="course-card" style="@(course.Color != null ? $"border-top:4px solid {course.Color};" : "")">
                            <h2>@course.Title</h2>
                            <div class="course-desc">@course.Description</div>
                            <div class="module-count">@course.Modules.Count мод. · @lessonCount ур.</div>
                            <div class="progress-bar">
                                <div class="progress-fill" style="width:@pct%"></div>
                            </div>
                            <div class="progress-label">
                                <span>Прогресс</span>
                                <span>@pct%</span>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }

    </div>
</div>

<script>
    var btn = document.getElementById("theme-btn");
    btn.textContent = localStorage.getItem("theme") === "dark" ? "☀️" : "🌙";
    function toggleTheme() {
        var isDark = document.documentElement.getAttribute("data-theme") === "dark";
        document.documentElement.setAttribute("data-theme", isDark ? "light" : "dark");
        localStorage.setItem("theme", isDark ? "light" : "dark");
        btn.textContent = isDark ? "🌙" : "☀️";
    }
</script>
</body>
</html>
