@page "/Modules/video/{moduleId}"
@model ModulesVideoModel
@{
    ViewData["Title"] = Model.Module?.Title ?? "Видео";
}

<div style="min-height: 100vh; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 40px 20px;">
    <div style="max-width: 900px; margin: 0 auto;">
        
        <a href="/" style="color: white; text-decoration: none; font-size: 1.1em; margin-bottom: 20px; display: inline-block;">
            ← Вернуться на дашборд
        </a>

        @if (Model.Module != null)
        {
            <div style="background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 20px 40px rgba(0,0,0,0.3);">
                
                <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 30px; color: white;">
                    <h1 style="margin: 0; font-size: 2em;">🎬 @Model.Module.Title</h1>
                    @if (!string.IsNullOrEmpty(Model.Module.VideoDescription))
                    {
                        <p style="margin: 10px 0 0 0; font-size: 1em; opacity: 0.9;">@Model.Module.VideoDescription</p>
                    }
                </div>

                <div style="padding: 30px;">
                    @if (!string.IsNullOrEmpty(Model.Module.YoutubeId))
                    {
                        <div style="position: relative; width: 100%; padding-bottom: 56.25%; margin-bottom: 30px; background: #000; border-radius: 8px; overflow: hidden;">
                            <iframe 
                                style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none;"
                                src="https://www.youtube.com/embed/@Model.Module.YoutubeId"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                allowfullscreen>
                            </iframe>
                        </div>
                    }

                    @if (Model.IsCompleted)
                    {
                        <div style="background: #d1fae5; border: 2px solid #10b981; border-radius: 8px; padding: 20px; text-align: center; color: #10b981; font-weight: bold; margin-bottom: 20px;">
                            ✅ Видеоурок завершён!
                        </div>
                    }
                    else
                    {
                        <form method="post" style="text-align: center;">
                            <button type="submit" style="background: #667eea; color: white; border: none; padding: 15px 40px; border-radius: 8px; font-size: 1.1em; cursor: pointer; font-weight: bold;">
                                ✓ Отметить как завершённое
                            </button>
                        </form>
                    }
                </div>
            </div>
        }
        else
        {
            <div style="background: white; border-radius: 10px; padding: 30px; text-align: center; color: #666;">
                <p style="font-size: 1.1em;">Видео не найдено</p>
            </div>
        }

    </div>
</div>
