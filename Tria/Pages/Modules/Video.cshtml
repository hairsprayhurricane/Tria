@page "/Modules/video/{moduleId}"
@model ModulesVideoModel
@using Tria.Services
@inject IUiLocalizer T
@{
    ViewData["Title"] = Model.Module?.Title ?? "Video";
    Layout = null;
    var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}

<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <script>(function(){ if(localStorage.getItem("theme")==="dark") document.documentElement.setAttribute("data-theme","dark"); })();</script>
    <title>@ViewData["Title"] – Tria</title>
    <style>
        :root { --bg:#f3f4f6; --surface:#ffffff; --surface-2:#f9fafb; --border:#d1d5db; --border-2:#e5e7eb; --text:#111827; --text-muted:#6b7280; --text-sub:#4b5563; --text-light:#374151; --progress-bg:#e5e7eb; --shadow:rgba(0,0,0,0.06); }
        [data-theme="dark"] { --bg:#0f1117; --surface:#1a1d2e; --surface-2:#151826; --border:#2a2d3e; --border-2:#222536; --text:#f1f5f9; --text-muted:#94a3b8; --text-sub:#cbd5e1; --text-light:#e2e8f0; --progress-bg:#2a2d3e; --shadow:rgba(0,0,0,0.4); }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background-color: var(--bg); color: var(--text); transition: background-color 0.3s, color 0.3s; }
        .page { min-height: 100vh; padding: 24px; }
        .shell { max-width: 900px; margin: 0 auto; }

        .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
        .theme-btn {
            width: 34px; height: 34px; border: 1px solid var(--border); border-radius: 6px;
            background: var(--surface); cursor: pointer; font-size: 16px;
            display: flex; align-items: center; justify-content: center;
            transition: border-color 0.2s, background-color 0.3s;
        }
        .theme-btn:hover { border-color: var(--text-muted); }

        .back-link { display: inline-block; font-size: 13px; color: #2563eb; text-decoration: none; }
        .back-link:hover { text-decoration: underline; }
        .video-box { background-color: var(--surface); border-radius: 8px; border: 1px solid var(--border); box-shadow: 0 10px 24px var(--shadow); overflow: hidden; transition: background-color 0.3s, border-color 0.3s; }
        .video-header { padding: 18px 20px; border-bottom: 1px solid var(--border-2); background-color: var(--surface-2); transition: background-color 0.3s, border-color 0.3s; }
        .video-title { font-size: 20px; font-weight: 600; margin-bottom: 4px; }
        .video-subtitle { font-size: 13px; color: var(--text-sub); }
        .video-content { padding: 18px 20px 20px; }
        .video-frame-wrap { position: relative; width: 100%; padding-bottom: 56.25%; background-color: #000; border-radius: 6px; overflow: hidden; margin-bottom: 18px; }
        .video-frame-wrap iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; }
        .state-box { margin-top: 4px; padding: 12px 14px; border-radius: 6px; font-size: 14px; text-align: center; border: 1px solid; }
        .state-done { background-color: #ecfdf5; color: #15803d; border-color: #15803d; }
        .btn-primary { padding: 10px 26px; font-size: 14px; border-radius: 4px; border: 1px solid #2563eb; background-color: #2563eb; color: #f9fafb; cursor: pointer; }
        .btn-primary:hover { background-color: #1d4ed8; }
        .empty-box { background-color: var(--surface); border-radius: 6px; border: 1px solid var(--border); padding: 20px; text-align: center; color: var(--text-sub); font-size: 14px; }
    </style>
</head>
<body>
<div class="page">
    <div class="shell">

        <div class="top-bar">
            <a href="/" class="back-link">@T["Video_Back"]</a>
            <button type="button" class="theme-btn" id="theme-btn" onclick="toggleTheme()">🌙</button>
        </div>

        @if (Model.Module != null)
        {
            <section class="video-box">
                <header class="video-header">
                    <div class="video-title">@T["Video_Prefix"] @Model.Module.Title</div>
                    @if (!string.IsNullOrEmpty(Model.Module.VideoDescription))
                    {
                        <div class="video-subtitle">@Model.Module.VideoDescription</div>
                    }
                </header>
                <div class="video-content">
                    @if (!string.IsNullOrEmpty(Model.Module.YoutubeId))
                    {
                        <div class="video-frame-wrap">
                            <iframe src="https://www.youtube.com/embed/@Model.Module.YoutubeId"
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                    allowfullscreen></iframe>
                        </div>
                    }
                    @if (Model.IsCompleted)
                    {
                        <div class="state-box state-done">@T["Video_Done"]</div>
                    }
                    else
                    {
                        <form method="post" style="text-align:center;">
                            <button type="submit" class="btn-primary">@T["Video_MarkDone"]</button>
                        </form>
                    }
                </div>
            </section>
        }
        else
        {
            <div class="empty-box">@T["Video_NotFound"]</div>
        }
    </div>
</div>
<script>
    const btn = document.getElementById('theme-btn');
    btn.textContent = localStorage.getItem('theme') === 'dark' ? '☀️' : '🌙';
    function toggleTheme() {
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        document.documentElement.setAttribute('data-theme', isDark ? 'light' : 'dark');
        localStorage.setItem('theme', isDark ? 'light' : 'dark');
        btn.textContent = isDark ? '🌙' : '☀️';
    }
</script>
</body>
</html>
