@page "/Modules/video/{moduleId}"
@model ModulesVideoModel
@using Tria.Services
@inject IUiLocalizer T
@{
    ViewData["Title"] = Model.Module?.Title ?? "Video";
    Layout = null;
    var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}

<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] – Tria</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background-color: #f3f4f6; color: #111827; }
        .page { min-height: 100vh; padding: 24px; }
        .shell { max-width: 900px; margin: 0 auto; }
        .back-link { display: inline-block; font-size: 13px; color: #2563eb; text-decoration: none; margin-bottom: 16px; }
        .back-link:hover { text-decoration: underline; }
        .video-box { background-color: #fff; border-radius: 8px; border: 1px solid #d1d5db; box-shadow: 0 10px 24px rgba(0,0,0,0.06); overflow: hidden; }
        .video-header { padding: 18px 20px; border-bottom: 1px solid #e5e7eb; background-color: #f9fafb; }
        .video-title { font-size: 20px; font-weight: 600; margin-bottom: 4px; }
        .video-subtitle { font-size: 13px; color: #4b5563; }
        .video-content { padding: 18px 20px 20px; }
        .video-frame-wrap { position: relative; width: 100%; padding-bottom: 56.25%; background-color: #000; border-radius: 6px; overflow: hidden; margin-bottom: 18px; }
        .video-frame-wrap iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; }
        .state-box { margin-top: 4px; padding: 12px 14px; border-radius: 6px; font-size: 14px; text-align: center; border: 1px solid; }
        .state-done { background-color: #ecfdf5; color: #15803d; border-color: #15803d; }
        .btn-primary { padding: 10px 26px; font-size: 14px; border-radius: 4px; border: 1px solid #2563eb; background-color: #2563eb; color: #f9fafb; cursor: pointer; }
        .btn-primary:hover { background-color: #1d4ed8; }
        .empty-box { background-color: #fff; border-radius: 6px; border: 1px solid #d1d5db; padding: 20px; text-align: center; color: #4b5563; font-size: 14px; }
    </style>
</head>
<body>
<div class="page">
    <div class="shell">
        <a href="/" class="back-link">@T["Video_Back"]</a>

        @if (Model.Module != null)
        {
            <section class="video-box">
                <header class="video-header">
                    <div class="video-title">@T["Video_Prefix"] @Model.Module.Title</div>
                    @if (!string.IsNullOrEmpty(Model.Module.VideoDescription))
                    {
                        <div class="video-subtitle">@Model.Module.VideoDescription</div>
                    }
                </header>
                <div class="video-content">
                    @if (!string.IsNullOrEmpty(Model.Module.YoutubeId))
                    {
                        <div class="video-frame-wrap">
                            <iframe src="https://www.youtube.com/embed/@Model.Module.YoutubeId"
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                    allowfullscreen></iframe>
                        </div>
                    }
                    @if (Model.IsCompleted)
                    {
                        <div class="state-box state-done">@T["Video_Done"]</div>
                    }
                    else
                    {
                        <form method="post" style="text-align:center;">
                            <button type="submit" class="btn-primary">@T["Video_MarkDone"]</button>
                        </form>
                    }
                </div>
            </section>
        }
        else
        {
            <div class="empty-box">@T["Video_NotFound"]</div>
        }
    </div>
</div>
</body>
</html>
