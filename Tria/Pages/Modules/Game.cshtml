@page "/Modules/game/{moduleId}"
@model ModulesGameModel
@using Tria.Services
@inject IUiLocalizer T
@{
ViewData["Title"] = Model.Module?.Title ?? "Game";
Layout = null;
var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
var gamePath = Model.GameBasePath;
}

<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <script>(function(){ if(localStorage.getItem("theme")==="dark") document.documentElement.setAttribute("data-theme","dark"); })();</script>
    <title>@ViewData["Title"] – Tria</title>
    <style>
        :root { --bg:#f3f4f6; --surface:#ffffff; --surface-2:#f9fafb; --border:#d1d5db; --border-2:#e5e7eb; --text:#111827; --text-muted:#6b7280; --text-sub:#4b5563; --text-light:#374151; --progress-bg:#e5e7eb; --shadow:rgba(0,0,0,0.06); }
        [data-theme="dark"] { --bg:#0f1117; --surface:#1a1d2e; --surface-2:#151826; --border:#2a2d3e; --border-2:#222536; --text:#f1f5f9; --text-muted:#94a3b8; --text-sub:#cbd5e1; --text-light:#e2e8f0; --progress-bg:#2a2d3e; --shadow:rgba(0,0,0,0.4); }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background-color: var(--bg); color: var(--text); transition: background-color 0.3s, color 0.3s; }
        .page { min-height: 100vh; padding: 24px; }
        .shell { max-width: 900px; margin: 0 auto; }

        .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
        .theme-btn {
            width: 34px; height: 34px; border: 1px solid var(--border); border-radius: 6px;
            background: var(--surface); cursor: pointer; font-size: 16px;
            display: flex; align-items: center; justify-content: center;
            transition: border-color 0.2s, background-color 0.3s;
        }
        .theme-btn:hover { border-color: var(--text-muted); }

        .back-link { display: inline-block; font-size: 13px; color: #2563eb; text-decoration: none; }
        .back-link:hover { text-decoration: underline; }

        .video-box { background-color: var(--surface); border-radius: 8px; border: 1px solid var(--border); box-shadow: 0 10px 24px var(--shadow); overflow: hidden; transition: background-color 0.3s, border-color 0.3s; }
        .video-header { padding: 18px 20px; border-bottom: 1px solid var(--border-2); background-color: var(--surface-2); transition: background-color 0.3s, border-color 0.3s; }
        .video-title { font-size: 20px; font-weight: 600; margin-bottom: 4px; }
        .video-subtitle { font-size: 13px; color: var(--text-sub); }
        .video-content { padding: 18px 20px 20px; }

        /* Unity WebGL плеер */
        .unity-wrap {
            position: relative;
            width: 100%;
            padding-bottom: 56.25%; /* 16:9 */
            background-color: #000;
            border-radius: 6px;
            overflow: hidden;
            margin-bottom: 18px;
        }
        .unity-wrap canvas {
            position: absolute;
            top: 0; left: 0;
            width: 100% !important;
            height: 100% !important;
        }
        .unity-loading-overlay {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: #000;
            color: #fff;
            font-size: 14px;
            gap: 12px;
            z-index: 10;
            transition: opacity 0.4s;
        }
        .unity-loading-overlay.hidden { opacity: 0; pointer-events: none; }
        .unity-progress-bar {
            width: 200px; height: 6px;
            background: #333; border-radius: 3px; overflow: hidden;
        }
        .unity-progress-fill {
            height: 100%; width: 0%; background: #2563eb;
            border-radius: 3px; transition: width 0.2s;
        }
        .unity-error {
            position: absolute; inset: 0;
            display: none;
            align-items: center; justify-content: center;
            background: #000; color: #f87171;
            font-size: 14px; text-align: center; padding: 20px;
        }

        .state-box { margin-top: 4px; padding: 12px 14px; border-radius: 6px; font-size: 14px; text-align: center; border: 1px solid; }
        .state-done { background-color: #ecfdf5; color: #15803d; border-color: #15803d; }
        .empty-box { background-color: var(--surface); border-radius: 6px; border: 1px solid var(--border); padding: 20px; text-align: center; color: var(--text-sub); font-size: 14px; }

        .fullscreen-btn {
            display: block;
            margin: 0 auto 4px;
            padding: 7px 20px;
            font-size: 13px;
            border-radius: 4px;
            border: 1px solid var(--border);
            background: var(--surface-2);
            color: var(--text);
            cursor: pointer;
            transition: border-color 0.2s;
        }
        .fullscreen-btn:hover { border-color: var(--text-muted); }
    </style>
</head>
<body>
<div class="page">
    <div class="shell">

        <div class="top-bar">
            <a href="/" class="back-link">@T["Video_Back"]</a>
            <button type="button" class="theme-btn" id="theme-btn" onclick="toggleTheme()">🌙</button>
        </div>

        @if (Model.Module != null)
        {
        <section class="video-box">
            <header class="video-header">
                <div class="video-title">🎮 @Model.Module.Title</div>
                @if (!string.IsNullOrEmpty((string?)Model.Module.VideoDescription))
                {
                <div class="video-subtitle">@Model.Module.VideoDescription</div>
                }
            </header>
            <div class="video-content">

                <div class="unity-wrap" id="unity-container">
                    <!-- Оверлей загрузки -->
                    <div class="unity-loading-overlay" id="unity-loading">
                        <span id="unity-loading-text">Loading…</span>
                        <div class="unity-progress-bar">
                            <div class="unity-progress-fill" id="unity-progress-fill"></div>
                        </div>
                    </div>
                    <!-- Оверлей ошибки -->
                    <div class="unity-error" id="unity-error">
                        ⚠️ Failed to load game.<br/>
                        Check that the build files exist at <code>@gamePath</code>
                    </div>
                    <!-- Canvas Unity рендерит сюда -->
                    <canvas id="unity-canvas" tabindex="-1"></canvas>
                </div>

                <button class="fullscreen-btn" onclick="unityFullscreen()">⛶ Fullscreen</button>

                @if (Model.IsCompleted)
                {
                <div class="state-box state-done">@T["Video_Done"]</div>
                }
            </div>
        </section>
        }
        else
        {
        <div class="empty-box">@T["Game_NotFound"]</div>
        }
    </div>
</div>

@if (Model.Module != null)
{
<!-- Unity WebGL loader. Путь: Resources/GameContent/{blockKey}_Game/ -->
<script src="@(gamePath)/Build/@(Model.Module.Block?.Key ?? "")_Game.loader.js"
        onerror="showUnityError()"></script>
<script>
    var unityInstance = null;
    var gamePath = "@gamePath";
    var buildName = "@(Model.Module.Block?.Key ?? "")_Game";

    var config = {
        dataUrl:           gamePath + "/Build/" + buildName + ".data",
        frameworkUrl:      gamePath + "/Build/" + buildName + ".framework.js",
        codeUrl:           gamePath + "/Build/" + buildName + ".wasm",
        streamingAssetsUrl: gamePath + "/StreamingAssets",
        companyName:       "Tria",
        productName:       buildName,
        productVersion:    "1.0",
    };

    var canvas = document.getElementById("unity-canvas");
    var loadingOverlay = document.getElementById("unity-loading");
    var progressFill = document.getElementById("unity-progress-fill");
    var loadingText = document.getElementById("unity-loading-text");

    createUnityInstance(canvas, config, function(progress) {
        progressFill.style.width = (100 * progress) + "%";
        loadingText.textContent = "Loading… " + Math.round(progress * 100) + "%";
    }).then(function(instance) {
        unityInstance = instance;
        loadingOverlay.classList.add("hidden");
    }).catch(function(err) {
        showUnityError();
        console.error(err);
    });

    function showUnityError() {
        document.getElementById("unity-loading").style.display = "none";
        var errEl = document.getElementById("unity-error");
        errEl.style.display = "flex";
    }

    function unityFullscreen() {
        if (unityInstance) unityInstance.SetFullscreen(1);
    }
</script>
}

<script>
    const btn = document.getElementById('theme-btn');
    btn.textContent = localStorage.getItem('theme') === 'dark' ? '☀️' : '🌙';
    function toggleTheme() {
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        document.documentElement.setAttribute('data-theme', isDark ? 'light' : 'dark');
        localStorage.setItem('theme', isDark ? 'light' : 'dark');
        btn.textContent = isDark ? '🌙' : '☀️';
    }
</script>
</body>
</html>
