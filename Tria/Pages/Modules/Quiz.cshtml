@page "/Modules/quiz/{moduleId}"
@model ModulesQuizModel
@using Tria.Services
@inject IUiLocalizer T
@{
    ViewData["Title"] = Model.Module?.Title ?? "Quiz";
    Layout = null;
    var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}

<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <script>(function(){ if(localStorage.getItem("theme")==="dark") document.documentElement.setAttribute("data-theme","dark"); })();</script>
    <title>@ViewData["Title"] – Tria</title>
    <style>
        :root { --bg:#f3f4f6; --surface:#ffffff; --surface-2:#f9fafb; --border:#d1d5db; --border-2:#e5e7eb; --text:#111827; --text-muted:#6b7280; --text-sub:#4b5563; --text-light:#374151; --progress-bg:#e5e7eb; --shadow:rgba(0,0,0,0.06); }
        [data-theme="dark"] { --bg:#0f1117; --surface:#1a1d2e; --surface-2:#151826; --border:#2a2d3e; --border-2:#222536; --text:#f1f5f9; --text-muted:#94a3b8; --text-sub:#cbd5e1; --text-light:#e2e8f0; --progress-bg:#2a2d3e; --shadow:rgba(0,0,0,0.4); }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background-color: var(--bg); color: var(--text); transition: background-color 0.3s, color 0.3s; }
        .page { min-height: 100vh; padding: 24px; }
        .shell { max-width: 900px; margin: 0 auto; }

        .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
        .theme-btn {
            width: 34px; height: 34px; border: 1px solid var(--border); border-radius: 6px;
            background: var(--surface); cursor: pointer; font-size: 16px;
            display: flex; align-items: center; justify-content: center;
            transition: border-color 0.2s, background-color 0.3s;
        }
        .theme-btn:hover { border-color: var(--text-muted); }

        .back-link { display: inline-block; font-size: 13px; color: #2563eb; text-decoration: none; }
        .back-link:hover { text-decoration: underline; }
        .quiz-box { background-color: var(--surface); border-radius: 8px; border: 1px solid var(--border); box-shadow: 0 10px 24px var(--shadow); overflow: hidden; transition: background-color 0.3s, border-color 0.3s; }
        .quiz-header { padding: 18px 20px; border-bottom: 1px solid var(--border-2); background-color: var(--surface-2); transition: background-color 0.3s, border-color 0.3s; }
        .quiz-title { font-size: 20px; font-weight: 600; margin-bottom: 4px; }
        .quiz-subtitle { font-size: 13px; color: var(--text-sub); }
        .quiz-content { padding: 18px 20px 20px; }
        .question { padding: 14px 0; border-bottom: 1px solid var(--border-2); }
        .question:last-child { border-bottom: none; }
        .question-counter { font-size: 12px; color: var(--text-muted); margin-bottom: 4px; }
        .question-text { font-size: 14px; font-weight: 500; margin-bottom: 10px; }
        .options { display: flex; flex-direction: column; gap: 8px; }
        .option { display: flex; align-items: center; padding: 8px 10px; border-radius: 6px; border: 1px solid var(--border); cursor: pointer; transition: background-color 0.15s, border-color 0.15s; }
        .option:hover { background-color: var(--surface-2); border-color: #2563eb; }
        .option input[type="radio"] { margin-right: 10px; width: 16px; height: 16px; cursor: pointer; }
        .option label { cursor: pointer; font-size: 14px; color: var(--text); }
        .button-row { margin-top: 20px; text-align: center; }
        .btn-primary { padding: 10px 26px; font-size: 14px; border-radius: 4px; border: 1px solid #2563eb; background-color: #2563eb; color: #f9fafb; cursor: pointer; }
        .btn-primary:hover { background-color: #1d4ed8; }
        .result-box { margin-bottom: 18px; padding: 14px 16px; border-radius: 6px; font-size: 14px; text-align: center; border: 1px solid; }
        .result-ok { background-color: #ecfdf5; color: #15803d; border-color: #15803d; }
        .result-fail { background-color: #fef2f2; color: #b91c1c; border-color: #b91c1c; }
        .result-score { font-size: 22px; margin: 6px 0; }
    </style>
</head>
<body>
<div class="page">
    <div class="shell">

        <div class="top-bar">
            <a href="/" class="back-link">@T["Quiz_Back"]</a>
            <button type="button" class="theme-btn" id="theme-btn" onclick="toggleTheme()">🌙</button>
        </div>

        @if (Model.Module != null && Model.Quiz != null)
        {
            <section class="quiz-box">
                <header class="quiz-header">
                    <div class="quiz-title">@T["Quiz_Prefix"] @Model.Module.Title</div>
                    <div class="quiz-subtitle">@Model.Quiz.Description</div>
                </header>
                <div class="quiz-content">
                    @if (Model.ShowResult)
                    {
                        <div class="result-box @(Model.Passed ? "result-ok" : "result-fail")">
                            <div>@(Model.Passed ? T["Quiz_Passed"] : T["Quiz_Failed"])</div>
                            <div class="result-score">@Model.Score%</div>
                            <div>@T["Quiz_MinScore"] @Model.Quiz.PassScore%.</div>
                        </div>
                        <form method="post" style="text-align:center;">
                            <input type="hidden" name="resetQuiz" value="true" />
                            <button type="submit" class="btn-primary">@T["Quiz_Retake"]</button>
                        </form>
                    }
                    else
                    {
                        <form method="post">
                            @for (int i = 0; i < Model.Quiz.Questions.Count; i++)
                            {
                                var question = Model.Quiz.Questions[i];
                                <div class="question">
                                    <div class="question-counter">
                                        @T["Quiz_Question"] @(i + 1) @T["Quiz_Of"] @Model.Quiz.Questions.Count
                                    </div>
                                    <div class="question-text">@question.Text</div>
                                    <div class="options">
                                        @for (int j = 0; j < question.Options.Count; j++)
                                        {
                                            <div class="option">
                                                <input type="radio" id="q@(i)_opt@(j)" name="answer_@(i)" value="@(j)" required />
                                                <label for="q@(i)_opt@(j)">@question.Options[j]</label>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                            <div class="button-row">
                                <button type="submit" class="btn-primary">@T["Quiz_Submit"]</button>
                            </div>
                        </form>
                    }
                </div>
            </section>
        }
        else
        {
            <section class="quiz-box">
                <div class="quiz-content" style="text-align:center;">
                    <p style="font-size:14px; color:var(--text-sub);">@T["Quiz_NotFound"]</p>
                </div>
            </section>
        }
    </div>
</div>
<script>
    const btn = document.getElementById('theme-btn');
    btn.textContent = localStorage.getItem('theme') === 'dark' ? '☀️' : '🌙';
    function toggleTheme() {
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        document.documentElement.setAttribute('data-theme', isDark ? 'light' : 'dark');
        localStorage.setItem('theme', isDark ? 'light' : 'dark');
        btn.textContent = isDark ? '🌙' : '☀️';
    }
</script>
</body>
</html>
