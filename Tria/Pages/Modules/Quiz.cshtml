@page "/Modules/quiz/{moduleId}"
@model ModulesQuizModel
@using Tria.Services
@inject IUiLocalizer T
@{
    ViewData["Title"] = Model.Module?.Title ?? "Quiz";
    Layout = null;
    var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}

<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] – Tria</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background-color: #f3f4f6; color: #111827; }
        .page { min-height: 100vh; padding: 24px; }
        .shell { max-width: 900px; margin: 0 auto; }
        .back-link { display: inline-block; font-size: 13px; color: #2563eb; text-decoration: none; margin-bottom: 16px; }
        .back-link:hover { text-decoration: underline; }
        .quiz-box { background-color: #fff; border-radius: 8px; border: 1px solid #d1d5db; box-shadow: 0 10px 24px rgba(0,0,0,0.06); overflow: hidden; }
        .quiz-header { padding: 18px 20px; border-bottom: 1px solid #e5e7eb; background-color: #f9fafb; }
        .quiz-title { font-size: 20px; font-weight: 600; margin-bottom: 4px; }
        .quiz-subtitle { font-size: 13px; color: #4b5563; }
        .quiz-content { padding: 18px 20px 20px; }
        .question { padding: 14px 0; border-bottom: 1px solid #e5e7eb; }
        .question:last-child { border-bottom: none; }
        .question-counter { font-size: 12px; color: #6b7280; margin-bottom: 4px; }
        .question-text { font-size: 14px; font-weight: 500; margin-bottom: 10px; }
        .options { display: flex; flex-direction: column; gap: 8px; }
        .option { display: flex; align-items: center; padding: 8px 10px; border-radius: 6px; border: 1px solid #d1d5db; cursor: pointer; transition: background-color 0.15s, border-color 0.15s; }
        .option:hover { background-color: #eff6ff; border-color: #2563eb; }
        .option input[type="radio"] { margin-right: 10px; width: 16px; height: 16px; cursor: pointer; }
        .option label { cursor: pointer; font-size: 14px; color: #111827; }
        .button-row { margin-top: 20px; text-align: center; }
        .btn-primary { padding: 10px 26px; font-size: 14px; border-radius: 4px; border: 1px solid #2563eb; background-color: #2563eb; color: #f9fafb; cursor: pointer; }
        .btn-primary:hover { background-color: #1d4ed8; }
        .result-box { margin-bottom: 18px; padding: 14px 16px; border-radius: 6px; font-size: 14px; text-align: center; border: 1px solid; }
        .result-ok { background-color: #ecfdf5; color: #15803d; border-color: #15803d; }
        .result-fail { background-color: #fef2f2; color: #b91c1c; border-color: #b91c1c; }
        .result-score { font-size: 22px; margin: 6px 0; }
    </style>
</head>
<body>
<div class="page">
    <div class="shell">
        <a href="/" class="back-link">@T["Quiz_Back"]</a>

        @if (Model.Module != null && Model.Quiz != null)
        {
            <section class="quiz-box">
                <header class="quiz-header">
                    <div class="quiz-title">@T["Quiz_Prefix"] @Model.Module.Title</div>
                    <div class="quiz-subtitle">@Model.Quiz.Description</div>
                </header>
                <div class="quiz-content">
                    @if (Model.ShowResult)
                    {
                        <div class="result-box @(Model.Passed ? "result-ok" : "result-fail")">
                            <div>@(Model.Passed ? T["Quiz_Passed"] : T["Quiz_Failed"])</div>
                            <div class="result-score">@Model.Score%</div>
                            <div>@T["Quiz_MinScore"] @Model.Quiz.PassScore%.</div>
                        </div>
                        <form method="post" style="text-align:center;">
                            <input type="hidden" name="resetQuiz" value="true" />
                            <button type="submit" class="btn-primary">@T["Quiz_Retake"]</button>
                        </form>
                    }
                    else
                    {
                        <form method="post">
                            @for (int i = 0; i < Model.Quiz.Questions.Count; i++)
                            {
                                var question = Model.Quiz.Questions[i];
                                <div class="question">
                                    <div class="question-counter">
                                        @T["Quiz_Question"] @(i + 1) @T["Quiz_Of"] @Model.Quiz.Questions.Count
                                    </div>
                                    <div class="question-text">@question.Text</div>
                                    <div class="options">
                                        @for (int j = 0; j < question.Options.Count; j++)
                                        {
                                            <div class="option">
                                                <input type="radio" id="q@(i)_opt@(j)" name="answer_@(i)" value="@(j)" required />
                                                <label for="q@(i)_opt@(j)">@question.Options[j]</label>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                            <div class="button-row">
                                <button type="submit" class="btn-primary">@T["Quiz_Submit"]</button>
                            </div>
                        </form>
                    }
                </div>
            </section>
        }
        else
        {
            <section class="quiz-box">
                <div class="quiz-content" style="text-align:center;">
                    <p style="font-size:14px; color:#4b5563;">@T["Quiz_NotFound"]</p>
                </div>
            </section>
        }
    </div>
</div>
</body>
</html>
