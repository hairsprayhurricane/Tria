@page "/Achievements"
@model Tria.Pages.AchievementsModel
@using Tria.Services
@inject IUiLocalizer T
@{
    ViewData["Title"] = "Достижения";
    Layout = null;
    var lang = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    string TierLabel(string t) => t switch { "bronze" => "Бронза", "silver" => "Серебро", "gold" => "Золото", _ => t };
}
<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script>(function(){ if(localStorage.getItem("theme")==="dark") document.documentElement.setAttribute("data-theme","dark"); })();</script>
    <title>@ViewData["Title"] – Tria</title>
    <style>
        :root { --bg:#f3f4f6; --surface:#ffffff; --surface-2:#f9fafb; --border:#d1d5db; --border-2:#e5e7eb; --text:#111827; --text-muted:#6b7280; --text-sub:#4b5563; --progress-bg:#e5e7eb; --shadow:rgba(0,0,0,0.06); --accent:#2563eb; --accent-h:#1d4ed8; }
        [data-theme="dark"] { --bg:#0f1117; --surface:#1a1d2e; --surface-2:#151826; --border:#2a2d3e; --border-2:#222536; --text:#f1f5f9; --text-muted:#94a3b8; --text-sub:#cbd5e1; --progress-bg:#2a2d3e; --shadow:rgba(0,0,0,0.4); }
        * { box-sizing:border-box; margin:0; padding:0; }
        body { font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif; background:var(--bg); color:var(--text); transition:background-color 0.3s,color 0.3s; }
        a { color:var(--accent); text-decoration:none; }
        a:hover { text-decoration:underline; }
        .page { min-height:100vh; padding:24px; }
        .shell { max-width:960px; margin:0 auto; }
        .top-bar { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; gap:12px; flex-wrap:wrap; }
        .breadcrumbs { display:flex; gap:8px; align-items:center; font-size:14px; color:var(--text-muted); }
        .breadcrumbs a { color:var(--text-muted); }
        .breadcrumbs a:hover { color:var(--text); }
        .theme-btn { width:34px; height:34px; border:1px solid var(--border); border-radius:6px; background:var(--surface); cursor:pointer; font-size:16px; display:flex; align-items:center; justify-content:center; transition:border-color 0.2s,background-color 0.3s; }
        .theme-btn:hover { border-color:var(--text-muted); }
        .page-header { margin-bottom:28px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; }
        .page-header h1 { font-size:22px; font-weight:700; }
        .xp-chip { font-size:14px; background:var(--surface); border:1px solid var(--border); border-radius:99px; padding:6px 16px; font-weight:600; color:var(--accent); }
        .section-sep { margin:28px 0 16px; font-size:13px; font-weight:600; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.05em; }
        .ach-grid { display:grid; gap:14px; grid-template-columns:repeat(auto-fill, minmax(260px, 1fr)); }
        .ach-card { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:18px; display:flex; gap:14px; align-items:flex-start; transition:box-shadow 0.2s,background-color 0.3s; }
        .ach-card.earned { box-shadow:0 2px 12px var(--shadow); border-color:var(--border); }
        .ach-card.unearned { filter:grayscale(1); opacity:0.5; }
        .ach-icon { font-size:32px; flex-shrink:0; line-height:1; }
        .ach-body { display:flex; flex-direction:column; gap:4px; flex:1; min-width:0; }
        .ach-title { font-size:14px; font-weight:600; line-height:1.3; }
        .ach-desc { font-size:12px; color:var(--text-muted); line-height:1.4; }
        .tier-badge { display:inline-block; padding:2px 8px; border-radius:99px; font-size:11px; font-weight:600; margin-top:2px; }
        .tier-bronze { background:#fde68a; color:#92400e; }
        .tier-silver { background:#e2e8f0; color:#475569; }
        .tier-gold   { background:#fef3c7; color:#b45309; }
        [data-theme="dark"] .tier-bronze { background:#78350f; color:#fde68a; }
        [data-theme="dark"] .tier-silver { background:#334155; color:#cbd5e1; }
        [data-theme="dark"] .tier-gold   { background:#713f12; color:#fcd34d; }
        .earned-check { font-size:11px; color:#059669; font-weight:600; margin-top:2px; }
        [data-theme="dark"] .earned-check { color:#34d399; }
        .empty { text-align:center; color:var(--text-muted); padding:60px; font-size:14px; }
    </style>
</head>
<body>
<div class="page">
    <div class="shell">

        <div class="top-bar">
            <div class="breadcrumbs">
                <a href="/Dashboard">Дашборд</a>
                <span>/</span>
                <span style="color:var(--text);font-weight:500;">Достижения</span>
            </div>
            <button type="button" class="theme-btn" id="theme-btn" onclick="toggleTheme()">🌙</button>
        </div>

        <div class="page-header">
            <h1>Мои достижения</h1>
            <span class="xp-chip">⚡ @Model.TotalXp XP</span>
        </div>

        @if (!Model.Achievements.Any())
        {
            <div class="empty">Достижений пока нет.</div>
        }
        else
        {
            var earned   = Model.Achievements.Where(a => a.Earned).ToList();
            var unearned = Model.Achievements.Where(a => !a.Earned).ToList();

            @if (earned.Any())
            {
                <div class="section-sep">Получены (@earned.Count)</div>
                <div class="ach-grid">
                    @foreach (var a in earned)
                    {
                        <div class="ach-card earned">
                            <div class="ach-icon">@a.Icon</div>
                            <div class="ach-body">
                                <div class="ach-title">@a.Title</div>
                                <div class="ach-desc">@a.Description</div>
                                <span class="tier-badge tier-@a.Tier">@TierLabel(a.Tier)</span>
                                <div class="earned-check">✓ Получено</div>
                            </div>
                        </div>
                    }
                </div>
            }

            @if (unearned.Any())
            {
                <div class="section-sep">Ещё не получены (@unearned.Count)</div>
                <div class="ach-grid">
                    @foreach (var a in unearned)
                    {
                        <div class="ach-card unearned">
                            <div class="ach-icon">@a.Icon</div>
                            <div class="ach-body">
                                <div class="ach-title">@a.Title</div>
                                <div class="ach-desc">@a.Description</div>
                                <span class="tier-badge tier-@a.Tier">@TierLabel(a.Tier)</span>
                            </div>
                        </div>
                    }
                </div>
            }
        }

    </div>
</div>
<script>
    var btn = document.getElementById("theme-btn");
    btn.textContent = localStorage.getItem("theme") === "dark" ? "☀️" : "🌙";
    function toggleTheme() {
        var d = document.documentElement.getAttribute("data-theme") === "dark";
        document.documentElement.setAttribute("data-theme", d ? "light" : "dark");
        localStorage.setItem("theme", d ? "light" : "dark");
        btn.textContent = d ? "🌙" : "☀️";
    }
</script>
</body>
</html>
