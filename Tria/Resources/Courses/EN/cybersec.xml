<Course Id="1" Key="cybersec" Title="Cybersecurity Fundamentals"
        Description="A foundational course on cybersecurity: communications, devices, and networks"
        IsActive="true" Color="#2563eb" Access="public">
  <Modules>

    <Module Id="1" Key="communications" Title="Communications" Description="Phishing, messages, calls" Difficulty="Easy" Order="1" IsActive="true" HasGame="true" GameKey="communications_Game">
      <Lessons>
        <Lesson Id="1" Key="phishing" Title="Phishing" Difficulty="Easy" Order="1" IsActive="true">
          <Materials>
            <Material Type="Video" YoutubeId="kTM5ko9c4Sk" Title="Phishing: The Basics" />
          </Materials>
          <Test PassScore="50">
            <Question Type="MultipleChoice">
              <Text>What is phishing?</Text>
              <Options>
                <Option>Trying to steal data using fake emails/websites</Option>
                <Option>A type of antivirus</Option>
                <Option>A Wi-Fi setting</Option>
              </Options>
              <CorrectOptionIndex>0</CorrectOptionIndex>
            </Question>
            <Question Type="MultipleChoice">
              <Text>Best action for a suspicious email?</Text>
              <Options>
                <Option>Open the attachment immediately</Option>
                <Option>Do not click links; verify the sender</Option>
                <Option>Reply with your password</Option>
              </Options>
              <CorrectOptionIndex>1</CorrectOptionIndex>
            </Question>
          </Test>
        </Lesson>
      </Lessons>
    </Module>

    <Module Id="2" Key="devices" Title="Devices" Description="PC and mobile security" Difficulty="Medium" Order="2" IsActive="true" HasGame="true" GameKey="devices_Game">
      <Lessons>
        <Lesson Id="2" Key="updates" Title="Updates and Protection" Difficulty="Medium" Order="1" IsActive="true">
          <Materials>
            <Material Type="Video" YoutubeId="FdmsevEh6gQ" Title="Device Updates and Protection" />
          </Materials>
          <Test PassScore="50">
            <Question Type="MultipleChoice">
              <Text>Why install OS updates?</Text>
              <Options>
                <Option>To close security vulnerabilities</Option>
                <Option>To increase screen brightness</Option>
                <Option>To speed up charging</Option>
              </Options>
              <CorrectOptionIndex>0</CorrectOptionIndex>
            </Question>
            <Question Type="MultipleChoice">
              <Text>Best practice for passwords?</Text>
              <Options>
                <Option>Same password everywhere</Option>
                <Option>Password manager with unique passwords</Option>
                <Option>Password 123456</Option>
              </Options>
              <CorrectOptionIndex>1</CorrectOptionIndex>
            </Question>
          </Test>
        </Lesson>
      </Lessons>
    </Module>

    <Module Id="3" Key="networks" Title="Networks" Description="Wi-Fi, VPN and safe internet" Difficulty="Hard" Order="3" IsActive="true" HasGame="false">
      <Lessons>
        <Lesson Id="3" Key="public_wifi" Title="Public Wi-Fi" Difficulty="Hard" Order="1" IsActive="true">
          <Materials>
            <Material Type="Video" YoutubeId="pIamTzHVdnw" Title="Public Wi-Fi: The Dangers" />
          </Materials>
          <Test PassScore="50">
            <Question Type="MultipleChoice">
              <Text>Is public Wi-Fi always safe?</Text>
              <Options>
                <Option>Yes</Option>
                <Option>No, traffic can be intercepted</Option>
                <Option>Only safe at night</Option>
              </Options>
              <CorrectOptionIndex>1</CorrectOptionIndex>
            </Question>
            <Question Type="MultipleChoice">
              <Text>What does a VPN help with?</Text>
              <Options>
                <Option>Protecting traffic on untrusted networks</Option>
                <Option>Removing viruses</Option>
                <Option>Charging faster</Option>
              </Options>
              <CorrectOptionIndex>0</CorrectOptionIndex>
            </Question>
          </Test>
        </Lesson>
      </Lessons>
    </Module>

  </Modules>
